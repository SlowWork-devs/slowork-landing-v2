---
import type { CollectionEntry } from "astro:content";
import { Image, getImage } from "astro:assets";
import MainLayout from "./MainLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = Partial<CollectionEntry<"blog">["data"]>;

const {
  title,
  excerpt,
  date,
  image,
  localImage,
  language = "es",
  translationSlug,
} = Astro.props;

const alternateLang = language === "es" ? "en" : "es";
const alternateLink = translationSlug
  ? `/${alternateLang}/blog/${translationSlug}/`
  : `/${alternateLang}/blog/`;

const esBlogPath =
  language === "es"
    ? Astro.url.pathname
    : translationSlug
      ? `/es/blog/${translationSlug}/`
      : "/es/blog/";
const enBlogPath =
  language === "en"
    ? Astro.url.pathname
    : translationSlug
      ? `/en/blog/${translationSlug}/`
      : "/en/blog/";
const esBlogHref = new URL(esBlogPath, Astro.url.origin).href;
const enBlogHref = new URL(enBlogPath, Astro.url.origin).href;
const xDefaultBlogHref =
  language === "es" ? esBlogHref : translationSlug ? esBlogHref : enBlogHref;

const optimizedHeroImage = localImage 
  ? await getImage({ src: localImage, width: 1020, height: 510, format: 'webp' }) 
  : null;
---

<MainLayout
  lang={language}
  title={title || ""}
  description={excerpt || ""}
  headerAlternateLink={alternateLink}
  alternates={[
    { hreflang: "es", href: esBlogHref },
    { hreflang: "en", href: enBlogHref },
    { hreflang: "x-default", href: xDefaultBlogHref },
  ]}
>
  <Fragment slot="head">
    {optimizedHeroImage && (
      <link rel="preload" as="image" href={optimizedHeroImage.src} type="image/webp" fetchpriority="high" />
    )}
    {!optimizedHeroImage && image && <link rel="preload" as="image" href={image} fetchpriority="high" />}
  </Fragment>

  <main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">
    <article>
      <div class="w-full overflow-hidden rounded-2xl mb-8 md:mb-12">
        {localImage ? (
          <Image
            width={1020}
            height={510}
            src={localImage}
            alt={title || ""}
            fetchpriority="high"
            loading="eager"
            format="webp"
            class="w-full h-auto object-cover aspect-2/1"
          />
        ) : image ? (
          <img
            width={1020}
            height={510}
            src={image}
            alt={title || ""}
            fetchpriority="high"
            loading="eager"
            class="w-full h-auto object-cover aspect-2/1"
          />
        ) : null}
      </div>
      <div class="prose-container max-w-3xl mx-auto">
        <header class="mb-8 md:mb-12">
          <div class="text-sm text-primary/60 mb-2">
            {date && <FormattedDate date={date} />}
          </div>
          <h1 class="font-heading font-bold text-primary text-[clamp(1.5rem,4vw+1rem,2.5rem)] leading-tight tracking-tight">
            {title}
          </h1>
          <hr class="border-primary/20 my-6" />
        </header>
        <div class="prose prose-lg prose-headings:font-heading prose-p:mb-6 prose-img:rounded-3xl prose-img:mx-auto w-full max-w-none">
          <slot />
        </div>
      </div>
    </article>
  </main>
</MainLayout>
