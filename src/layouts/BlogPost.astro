---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import '../styles/global.css';

type Props = Partial<CollectionEntry<"blog">["data"]>;

const {
  title,
  excerpt,
  date,
  image,
  localImage,
  language = "es",
  translationSlug,
} = Astro.props;

const alternateLang = language === "es" ? "en" : "es";
const alternateLink = translationSlug
  ? `/${alternateLang}/blog/${translationSlug}/`
  : `/${alternateLang}/blog/`;
---

<!doctype html>
<html lang={language}>
  <head>
    <BaseHead title={title || ""} description={excerpt || ""} />

    <link rel="alternate" hreflang={language} href={Astro.url.href} />
    <link rel="alternate" hreflang={alternateLang} href={new URL(alternateLink, Astro.url.origin).href} />
  </head>

  <body class="min-w-0 overflow-x-hidden">
    <Header language={language} alternateLink={alternateLink} />
    <main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">
      <article>
        <div class="w-full overflow-hidden rounded-2xl mb-8 md:mb-12">
          {localImage ? (
            <Image
              width={1020}
              height={510}
              src={localImage}
              alt={title || ""}
              fetchpriority="high"
              class="w-full h-auto object-cover aspect-2/1"
            />
          ) : image ? (
            <img
              width={1020}
              height={510}
              src={image}
              alt={title || ""}
              class="w-full h-auto object-cover aspect-2/1"
            />
          ) : null}
        </div>
        <div class="prose-container max-w-3xl mx-auto">
          <header class="mb-8 md:mb-12">
            <div class="text-sm text-primary/60 mb-2">
              {date && <FormattedDate date={date} />}
            </div>
            <h1 class="font-heading font-bold text-primary text-[clamp(1.5rem,4vw+1rem,2.5rem)] leading-tight tracking-tight">
              {title}
            </h1>
            <hr class="border-primary/20 my-6" />
          </header>
          <div class="prose prose-lg prose-headings:font-heading prose-p:mb-6 prose-img:rounded-3xl prose-img:mx-auto w-full max-w-none">
            <slot />
          </div>
        </div>
      </article>
    </main>
    <Footer language={language} />
  </body>
</html>
