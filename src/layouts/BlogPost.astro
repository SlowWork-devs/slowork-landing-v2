---
import type { CollectionEntry } from "astro:content";
import { Image, getImage } from "astro:assets";
import MainLayout from "@/layouts/MainLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import BlogArticleBackButton from "@/components/ui/BlogArticleBackButton.astro";
import ScrollToTopButton from "@/components/ui/ScrollToTopButton.astro";
import type { SupportedLang } from "@/lib/seo";

type Props = Partial<CollectionEntry<"blog">["data"]>;

const {
  title,
  excerpt,
  date,
  image,
  localImage,
  language = "es",
  translationSlug,
} = Astro.props;

const esBlogPath =
  language === "es"
    ? Astro.url.pathname
    : translationSlug
      ? `/es/blog/${translationSlug}/`
      : "/es/blog/";
const enBlogPath =
  language === "en"
    ? Astro.url.pathname
    : translationSlug
      ? `/en/blog/${translationSlug}/`
      : "/en/blog/";
const esBlogHref = new URL(esBlogPath, Astro.url.origin).href;
const enBlogHref = new URL(enBlogPath, Astro.url.origin).href;
const xDefaultBlogHref =
  language === "es" ? esBlogHref : translationSlug ? esBlogHref : enBlogHref;

const blogLang: SupportedLang = language === "en" ? "en" : "es";

const optimizedHeroImage = localImage 
  ? await getImage({ src: localImage, width: 1020, height: 510, format: 'webp' }) 
  : null;
---

<MainLayout
  lang={language}
  title={title || ""}
  description={excerpt || ""}
  alternates={[
    { hreflang: "es", href: esBlogHref },
    { hreflang: "en", href: enBlogHref },
    { hreflang: "x-default", href: xDefaultBlogHref },
  ]}
>
  <Fragment slot="head">
    {optimizedHeroImage && (
      <link rel="preload" as="image" href={optimizedHeroImage.src} type="image/webp" fetchpriority="high" />
    )}
    {!optimizedHeroImage && image && <link rel="preload" as="image" href={image} fetchpriority="high" />}
  </Fragment>

  <main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">
    <article>
      <div class="w-full overflow-hidden rounded-2xl mb-8 md:mb-12">
        {localImage ? (
          <Image
            width={1020}
            height={510}
            src={localImage}
            alt={title || ""}
            fetchpriority="high"
            loading="eager"
            format="webp"
            class="w-full h-auto object-cover aspect-2/1"
          />
        ) : image ? (
          <img
            width={1020}
            height={510}
            src={image}
            alt={title || ""}
            fetchpriority="high"
            loading="eager"
            class="w-full h-auto object-cover aspect-2/1"
          />
        ) : null}
      </div>
      <div class="prose-container max-w-4xl mx-auto w-full">
        <div class="mb-12 flex justify-start">
          <BlogArticleBackButton lang={blogLang} />
        </div>
        <header class="mb-8 md:mb-12">
          <div class="text-sm text-primary/60 mb-2 capitalize">
            {date && <FormattedDate date={date} />}
          </div>
          <h1 class="font-heading font-bold text-primary text-[clamp(1.5rem,4vw+1rem,2.5rem)] leading-tight tracking-tight">
            {title}
          </h1>
          <hr class="border-primary/20 my-6" />
        </header>
        <div
          class="prose prose-neutral lg:prose-xl max-w-none w-full text-primary/90 selection:bg-secondary/30 prose-headings:font-heading prose-headings:text-primary prose-a:text-soft-blue prose-a:font-bold prose-a:no-underline prose-a:transition-colors hover:prose-a:text-primary prose-img:rounded-3xl prose-img:border-4 prose-img:border-light-green/50 prose-img:shadow-2xl prose-blockquote:border-l-[6px] prose-blockquote:border-l-secondary prose-blockquote:bg-light-green/20 prose-blockquote:px-8 prose-blockquote:py-4 prose-blockquote:rounded-r-2xl prose-blockquote:italic prose-blockquote:text-primary/80 prose-li:marker:font-bold prose-li:marker:text-secondary prose-hr:my-12 prose-hr:border-primary/10"
        >
          <slot />
        </div>
      </div>
    </article>
  </main>
  
  <ScrollToTopButton lang={blogLang} />
</MainLayout>
