---
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';

import '../styles/global.css';

import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import HomeWaitlistModal from '@/components/home/HomeWaitlistModal.astro';
import SocialShareBar from '@/components/ui/SocialShareBar.astro';
import FallbackImage from '@/assets/blog-placeholder-1.png';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import { languageSwitcherPaths } from '@/lib/hreflang';

type Alternate = {
  hreflang: string;
  href: string;
};

interface Props {
  lang: 'es' | 'en';
  title?: string;
  description?: string;
  canonical?: string;
  image?: ImageMetadata;
  /** URL absoluta (p. ej. CloudFront) para og:image / twitter cuando no hay asset local. */
  socialImage?: string;
  /** Meta keywords (opcional; uso editorial / otros buscadores). */
  keywords?: string[];
  ogType?: string;
  /** Incluir `es`, `en` y `x-default` (español como predeterminado); ver `buildI18nAlternates`. */
  alternates?: Alternate[];
  jsonLd?: unknown;
  showHeader?: boolean;
  showFooter?: boolean;
}

const {
  lang,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonical,
  image = FallbackImage,
  socialImage,
  keywords = [],
  ogType = 'website',
  alternates = [],
  jsonLd,
  showHeader = true,
  showFooter = true,
} = Astro.props;

const langSwitcher = languageSwitcherPaths({
  alternates,
  pathname: Astro.url.pathname,
  origin: Astro.url.origin,
});

const canonicalURL = canonical
  ? new URL(canonical, Astro.site ?? Astro.url.origin)
  : new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

const ogImageHref =
  socialImage && /^https?:\/\//i.test(socialImage)
    ? socialImage
    : new URL(image.src, Astro.url).href;

const gaId = import.meta.env.PUBLIC_GA_ID?.trim() ?? '';
const gaEnabled = gaId.length > 0;

const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <ClientRouter />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta name="publisher" content="Slowork" />
    <meta name="application-name" content={SITE_TITLE} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site ?? Astro.url.origin)} />

    <meta name="generator" content={Astro.generator} />

    <link rel="preload" href="/fonts/poppins-regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/poppins-bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} />
    {description && <meta name="description" content={description} />}
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageHref} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    {description && <meta property="twitter:description" content={description} />}
    <meta property="twitter:image" content={ogImageHref} />

    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {gaEnabled && (
      <>
        <script
          type="text/partytown"
          src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
        />
        <script type="text/partytown" define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag() {
            dataLayer.push(arguments);
          };
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <slot name="head" />
  </head>

  <body id="slowork-layout-root" class="min-w-0 overflow-x-hidden">
    {showHeader && <Header language={lang} langHrefEs={langSwitcher.es} langHrefEn={langSwitcher.en} />}
    <SocialShareBar language={lang} />
    <slot />
    <HomeWaitlistModal lang={lang} />
    {showFooter && <Footer language={lang} />}

    <script is:inline>
      (() => {
        let waitlistUiAbort;
        const bindWaitlistModal = () => {
          waitlistUiAbort?.abort();
          waitlistUiAbort = new AbortController();
          const { signal } = waitlistUiAbort;

          const overlay = document.getElementById('modal-overlay');
          const modal = document.getElementById('waitlist-modal');
          if (!overlay || !modal) return;

          const openModal = () => {
            overlay.classList.remove('hidden');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          };
          const closeModal = () => {
            overlay.classList.add('hidden');
            modal.classList.add('hidden');
            document.body.style.overflow = '';
          };

          const onDocClick = (e) => {
            const opener = e.target?.closest?.('[data-open-waitlist]');
            if (!opener) return;
            e.preventDefault();
            openModal();
          };

          document.addEventListener('click', onDocClick, { signal });
          overlay.addEventListener('click', closeModal, { signal });
          document.getElementById('close-waitlist')?.addEventListener('click', closeModal, { signal });
          document.addEventListener(
            'keydown',
            (e) => {
              if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
            },
            { signal },
          );
        };

        bindWaitlistModal();
        document.addEventListener('astro:page-load', bindWaitlistModal);
      })();
    </script>
  </body>
</html>

