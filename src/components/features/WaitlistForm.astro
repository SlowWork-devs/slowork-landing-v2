---
import { Image } from 'astro:assets';
import type { SupportedLang } from '@/lib/seo';
import { waitlistFormCopy } from '@/lib/homeContent';
import { getLegalBundle } from '@/lib/legalBundle';
import TermsPolicyDialog from '@/components/legal/TermsPolicyDialog.astro';
import lifestyleWorkingHero from '@/assets/lifestyle-working.jpg';

interface Props {
  lang: SupportedLang;
  /** `full`: bloque dos columnas como la landing React. `minimal`: solo campos (p. ej. modal). */
  layout?: 'full' | 'minimal';
}

const { lang, layout = 'full' } = Astro.props;
const c = waitlistFormCopy(lang);
const termsHref = `/${lang}/terms-and-conditions/`;
const legalTerms = getLegalBundle(lang).termsAndConditions;
const homeHref = `/${lang}/`;
const suffix = `${layout}-${lang}`;
const ringOffset = layout === 'full' ? 'focus:ring-offset-light-green' : 'focus:ring-offset-bg-landing';

/** `full`: id estable para intl-tel-input; `minimal`: evita duplicar id en la misma página (modal + hero). */
const phoneInputId = layout === 'full' ? 'phone-input' : `phone-input-${suffix}`;

const rootClass =
  layout === 'full'
    ? 'waitlist-form-root card lg:card-side bg-base-100 mx-auto my-8 flex w-full max-w-full min-w-0 min-h-[700px] flex-col overflow-x-hidden overflow-y-visible border border-primary/10 font-sans shadow-xl sm:max-w-6xl lg:flex-row'
    : 'waitlist-form-root card lg:card-side flex w-full max-w-full min-w-0 min-h-0 flex-1 flex-col overflow-x-hidden overflow-y-visible border-0 bg-transparent font-sans shadow-none lg:flex-row';

const formShellClass =
  layout === 'full'
    ? 'card-body relative z-10 flex min-h-0 min-w-0 flex-1 flex-col justify-center gap-0 overflow-x-hidden bg-bg-landing p-6 sm:p-8 lg:p-10 lg:w-[65%] lg:max-w-[65%] lg:flex-none lg:min-w-0'
    : 'card-body relative z-10 flex min-h-0 min-w-0 flex-1 flex-col justify-start gap-0 overflow-x-hidden bg-bg-landing px-4 py-4 sm:px-5 sm:py-5 lg:w-[65%] lg:max-w-[65%] lg:flex-none lg:min-w-0';

const successOverlayBg = 'bg-bg-landing';

/** Landing: franja imagen en móvil; desktop 35 % fijo. */
const heroFigureFullClass =
  'relative order-1 flex h-48 w-full min-w-0 shrink-0 flex-col overflow-hidden lg:order-none lg:flex lg:h-auto lg:min-h-[700px] lg:w-[35%] lg:max-w-[35%] lg:flex-none lg:self-stretch';

/** Modal: sin imagen bajo lg (prioriza formulario); desde lg proporción 35/65. */
const heroFigureMinimalClass =
  'relative order-1 hidden min-w-0 shrink-0 flex-col overflow-hidden lg:order-none lg:flex lg:h-auto lg:min-h-[min(420px,52vh)] lg:w-[35%] lg:max-w-[35%] lg:flex-none lg:self-stretch';

const sectionStackClass = layout === 'minimal' ? 'space-y-4' : 'space-y-6';
const fieldGridGapClass = layout === 'minimal' ? 'gap-4' : 'gap-x-6 gap-y-6';
const formStackGapClass = layout === 'minimal' ? 'gap-4' : 'gap-10';

const labelTextClass =
  'label-text block w-full max-w-full text-pretty break-words text-left font-bold text-primary/70 text-[0.65rem] uppercase tracking-wide hyphens-auto sm:text-xs sm:tracking-widest';
const labelRowClass =
  'label flex w-full min-w-0 flex-wrap items-start gap-x-1 cursor-default px-0 pb-1.5 pt-0 sm:pb-1';
const sectionHeadingClass =
  'max-w-full text-pretty break-words text-xs font-bold uppercase tracking-[0.2em] text-primary/60 hyphens-auto';
const waitlistControlShellClass = 'waitlist-control-shell relative w-full min-w-0';
const inputClass = `input input-bordered input-lg w-full max-w-full bg-white/90 backdrop-blur-sm border-primary/25 text-primary transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 focus:ring-offset-2 ${ringOffset}`;
const selectClass = `select select-bordered select-lg w-full max-w-full bg-white/90 backdrop-blur-sm border-primary/25 text-primary transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 focus:ring-offset-2 ${ringOffset}`;
const textareaClass = `textarea textarea-bordered textarea-lg w-full max-w-full min-h-28 resize-y bg-white/90 backdrop-blur-sm border-primary/25 text-primary transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 focus:ring-offset-2 ${ringOffset}`;
const inputWithIconClass = `${inputClass} pl-10`;
const errText =
  'mt-1.5 flex h-[2.75rem] shrink-0 items-start overflow-hidden text-xs font-semibold leading-snug text-error opacity-0 transition-opacity duration-200 ease-out data-[visible=true]:opacity-100';
---

<div
  class={rootClass}
  data-waitlist-layout={layout}
  data-lang={lang}
  data-waitlist-sending={c.sending}
  data-waitlist-success={c.success}
  data-waitlist-error={c.error}
  data-waitlist-send-failed={c.sendFailed}
  data-waitlist-button={c.button}
  data-waitlist-validation={JSON.stringify(c.validation)}
  data-success-inside-before={c.successInsideBefore}
  data-success-inside-after={c.successInsideAfter}
>
  <figure class={layout === 'full' ? heroFigureFullClass : heroFigureMinimalClass}>
    <Image
      src={lifestyleWorkingHero}
      alt=""
      width={1600}
      height={1200}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="pointer-events-none absolute inset-0 bg-primary/20" aria-hidden="true" />
    <figcaption class="sr-only">
      {c.waitingList}: {c.titlePart1} {c.titleHighlight1}
    </figcaption>
    <div class="relative z-10 flex h-full w-full min-w-0 flex-col items-center justify-center px-5 py-6 sm:px-8">
      <h2
        class="max-w-[20ch] text-center font-heading text-[clamp(1.125rem,3.5vw,2rem)] font-semibold leading-tight tracking-wide text-bg-landing sm:max-w-[24ch] lg:max-w-[18ch]"
      >
        {c.titlePart1}{' '}
        <span class="font-extrabold text-secondary">{c.titleHighlight1}</span>
      </h2>
    </div>
  </figure>

  <div class={formShellClass}>
      <div class="relative isolate z-0 flex min-h-0 w-full min-w-0 flex-1 flex-col">
        <div
          class="relative z-10 transition-opacity duration-300 ease-out data-[state=hidden]:pointer-events-none data-[state=hidden]:invisible data-[state=hidden]:opacity-0"
          data-waitlist-form-panel
          data-state="visible"
        >
          <form class:list={['flex h-full min-h-0 w-full min-w-0 flex-col', formStackGapClass]} data-waitlist-form novalidate>
            <h2 class="text-center font-heading text-lg font-bold text-primary sm:text-xl md:text-2xl">
              {c.formTitle}
            </h2>

            <section class:list={[sectionStackClass]} aria-labelledby={`wl-sec-personal-${suffix}`}>
              <h3 id={`wl-sec-personal-${suffix}`} class={sectionHeadingClass}>
                {c.sectionPersonal}
              </h3>
              <div class:list={['grid grid-cols-1 lg:grid-cols-3', fieldGridGapClass]}>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-fn-${suffix}`}>
                    <span class={labelTextClass}>
                      {c.firstName}
                      <span class="text-soft-blue">*</span>
                    </span>
                  </label>
                  <div class={waitlistControlShellClass}>
                    <input
                      id={`wl-fn-${suffix}`}
                      name="firstName"
                      type="text"
                      autocomplete="given-name"
                      data-waitlist-field="firstName"
                      class={inputClass}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-firstName-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="firstName"
                    data-visible="false"
                  />
                </div>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-em-${suffix}`}>
                    <span class={labelTextClass}>
                      {c.email}
                      <span class="text-soft-blue">*</span>
                    </span>
                  </label>
                  <div class={waitlistControlShellClass}>
                    <input
                      id={`wl-em-${suffix}`}
                      name="email"
                      type="email"
                      autocomplete="email"
                      data-waitlist-field="email"
                      class={inputClass}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-email-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="email"
                    data-visible="false"
                  />
                </div>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={phoneInputId}>
                    <span class={labelTextClass}>
                      {c.phone}
                      <span class="text-soft-blue">*</span>
                    </span>
                  </label>
                  <div class={waitlistControlShellClass}>
                    <input
                      id={phoneInputId}
                      name="phone"
                      type="tel"
                      autocomplete="tel"
                      data-waitlist-field="phone"
                      class={`${inputClass} pl-14!`}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-phone-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="phone"
                    data-visible="false"
                  />
                </div>
              </div>
            </section>

            <section class:list={[sectionStackClass]} aria-labelledby={`wl-sec-social-${suffix}`}>
              <h3 id={`wl-sec-social-${suffix}`} class={sectionHeadingClass}>
                {c.sectionSocial}
              </h3>
              <div class:list={['grid grid-cols-1 lg:grid-cols-2', fieldGridGapClass]}>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-ig-${suffix}`}>
                    <span class={labelTextClass}>{c.instagram}</span>
                  </label>
                  <div class:list={['group/fi', waitlistControlShellClass]}>
                    <span
                      class="pointer-events-none absolute left-3 top-1/2 z-10 -translate-y-1/2 text-primary/35 transition-colors group-focus-within/fi:text-primary/55"
                      aria-hidden="true"
                    >
                      <svg class="size-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.75" />
                        <circle cx="12" cy="12" r="3.25" stroke="currentColor" stroke-width="1.75" />
                        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
                      </svg>
                    </span>
                    <input
                      id={`wl-ig-${suffix}`}
                      name="instagram"
                      type="text"
                      autocomplete="off"
                      data-waitlist-field="instagram"
                      class={inputWithIconClass}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-instagram-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="instagram"
                    data-visible="false"
                  />
                </div>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-li-${suffix}`}>
                    <span class={labelTextClass}>{c.linkedin}</span>
                  </label>
                  <div class:list={['group/fi', waitlistControlShellClass]}>
                    <span
                      class="pointer-events-none absolute left-3 top-1/2 z-10 -translate-y-1/2 text-primary/35 transition-colors group-focus-within/fi:text-primary/55"
                      aria-hidden="true"
                    >
                      <svg class="size-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.75" />
                        <path
                          d="M8 10v7M8 8.2V8M12 17v-4.2c0-1.1.9-2 2-2s2 .9 2 2V17M16 10v7"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                        />
                      </svg>
                    </span>
                    <input
                      id={`wl-li-${suffix}`}
                      name="linkedin"
                      type="text"
                      inputmode="url"
                      autocomplete="url"
                      data-waitlist-field="linkedin"
                      class={inputWithIconClass}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-linkedin-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="linkedin"
                    data-visible="false"
                  />
                </div>
              </div>
            </section>

            <section class:list={[sectionStackClass]} aria-labelledby={`wl-sec-pref-${suffix}`}>
              <h3 id={`wl-sec-pref-${suffix}`} class={sectionHeadingClass}>
                {c.sectionPreferences}
              </h3>
              <div class:list={['grid grid-cols-1', fieldGridGapClass]}>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-pref-${suffix}`}>
                    <span class={labelTextClass}>
                      {c.preferredContact}
                      <span class="text-soft-blue">*</span>
                    </span>
                  </label>
                  <div class={waitlistControlShellClass}>
                    <select
                      id={`wl-pref-${suffix}`}
                      name="preferredContact"
                      required
                      data-waitlist-field="preferredContact"
                      class={selectClass}
                      aria-invalid="false"
                    >
                      <option value="">{c.selectDefault}</option>
                      <option value="Sloworker">{c.optSloworker}</option>
                      <option value="Host">{c.optHost}</option>
                      <option value="Business">{c.optBusiness}</option>
                    </select>
                  </div>
                  <p
                    id={`wl-err-preferredContact-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="preferredContact"
                    data-visible="false"
                  />
                </div>
                <div class="form-control w-full min-w-0">
                  <label class={labelRowClass} for={`wl-com-${suffix}`}>
                    <span class={labelTextClass}>
                      {c.communityInterest}
                      <span class="text-soft-blue">*</span>
                    </span>
                  </label>
                  <div class={waitlistControlShellClass}>
                    <textarea
                      id={`wl-com-${suffix}`}
                      name="communityInterest"
                      rows={4}
                      data-waitlist-field="communityInterest"
                      class={textareaClass}
                      aria-invalid="false"
                    />
                  </div>
                  <p
                    id={`wl-err-communityInterest-${suffix}`}
                    role="alert"
                    class={errText}
                    data-waitlist-err="communityInterest"
                    data-visible="false"
                  />
                </div>
              </div>
            </section>

            <div class="mb-6 flex flex-col gap-2">
              <div class="flex min-w-0 items-start gap-3">
                <input
                  id={`waitlist-terms-${layout}-${lang}`}
                  name="termsAccepted"
                  type="checkbox"
                  data-waitlist-field="terms"
                  class="peer/terms mt-1 size-5 shrink-0 cursor-pointer rounded border-primary text-primary accent-primary focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:outline-none"
                  aria-invalid="false"
                />
                <div
                  class="min-w-0 flex-1 text-pretty text-sm font-semibold leading-snug text-primary hyphens-auto"
                >
                  <label for={`waitlist-terms-${layout}-${lang}`} class="cursor-pointer text-inherit">
                    {c.termsBefore}
                  </label>
                  <button
                    type="button"
                    class="mx-0.5 inline cursor-pointer border-0 bg-transparent p-0 text-left text-sm font-semibold text-soft-blue underline decoration-2 underline-offset-2 transition hover:text-primary focus:outline-none focus-visible:rounded focus-visible:ring-2 focus-visible:ring-soft-blue focus-visible:ring-offset-2"
                    data-open-waitlist-terms-dialog
                    aria-haspopup="dialog"
                    aria-controls={`waitlist-terms-dialog-${suffix}`}
                  >
                    {c.termsLink}
                  </button>
                  <label for={`waitlist-terms-${layout}-${lang}`} class="cursor-pointer text-inherit">
                    {c.termsAfter}
                    <span class="text-soft-blue"> *</span>
                  </label>
                </div>
              </div>
              <p
                id={`wl-err-terms-${suffix}`}
                role="alert"
                class={errText}
                data-waitlist-err="terms"
                data-visible="false"
              />
            </div>

            <div class="flex flex-col items-stretch gap-4 sm:flex-row sm:items-center sm:justify-between">
              <button
                type="submit"
                data-waitlist-submit-btn
                data-busy="false"
                data-status="idle"
                class="btn btn-primary group/submit relative min-h-12 min-w-44 overflow-hidden px-8 font-semibold transition enabled:active:scale-[0.98] disabled:cursor-not-allowed disabled:bg-primary/45 data-[status=sending]:animate-pulse data-[status=sending]:cursor-wait data-[status=sending]:shadow-[0_0_0_3px_rgba(1,51,51,0.18)]"
              >
                <span class="inline-flex items-center justify-center gap-2.5">
                  <svg
                    data-waitlist-spinner
                    class="hidden size-4 shrink-0 animate-spin text-secondary"
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"
                  >
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                    <path
                      class="opacity-90"
                      fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                    />
                  </svg>
                  <span data-waitlist-submit-label>{c.button}</span>
                </span>
              </button>
              <p
                role="status"
                aria-live="polite"
                data-waitlist-status
                data-status="idle"
                class="min-h-5 text-sm font-semibold text-primary/80 data-[status=error]:text-soft-blue data-[status=sending]:text-primary/60 data-[status=success]:sr-only"
              />
            </div>
          </form>
        </div>

        <div
          class={`absolute inset-0 z-20 flex flex-col items-center justify-center gap-6 px-4 py-6 text-center opacity-0 pointer-events-none transition-opacity duration-300 ease-out data-[state=visible]:pointer-events-auto data-[state=visible]:opacity-100 ${successOverlayBg}`}
          data-waitlist-success-panel
          data-state="hidden"
          aria-hidden="true"
        >
          <div
            class="w-full max-w-md rounded-2xl border border-primary/15 bg-light-green px-6 py-8 shadow-xl"
            role="status"
            aria-live="polite"
          >
            <p class="font-heading text-xl font-bold leading-snug text-primary sm:text-2xl" data-waitlist-success-headline />
            <p class="mt-3 text-sm text-primary/75">{c.successCardSub}</p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
              <button
                type="button"
                data-waitlist-success-close
                class="inline-flex min-h-11 items-center justify-center rounded-lg border-2 border-primary/20 bg-bg-landing px-6 font-semibold text-primary transition hover:border-primary/40"
              >
                {c.closeSuccess}
              </button>
              <a
                href={homeHref}
                class="inline-flex min-h-11 items-center justify-center rounded-lg bg-primary px-6 font-semibold text-secondary shadow transition hover:opacity-95"
              >
                {c.backHome}
              </a>
            </div>
          </div>
        </div>
      </div>
  </div>

  <TermsPolicyDialog
    terms={legalTerms}
    lang={lang}
    suffix={suffix}
    fullPageHref={termsHref}
    closeLabel={c.termsDialogClose}
    fullPageLabel={c.termsDialogOpenFullPage}
  />
</div>

<script>
  import {
    waitlistCreateBodySchema,
    createWaitlistFormSchema,
    createWaitlistFormFieldSchemas,
    WAITLIST_FORM_FIELD_NAMES,
  } from '@/models/waitlist';
  import type { WaitlistFormFieldName } from '@/models/waitlist';
  import { PhoneController } from '@/lib/waitlistPhoneController';

  type ValidationMsgs = {
    emailRequired: string;
    emailInvalid: string;
    firstNameRequired: string;
    phoneRequired: string;
    phoneInvalid: string;
    instagramInvalid: string;
    linkedinInvalid: string;
    preferredContactRequired: string;
    communityRequired: string;
    termsRequired: string;
  };

  const skipPayloadKeys = new Set(['termsAccepted']);

  const payloadFromForm = (form: HTMLFormElement): Record<string, string> => {
    const entries = Object.fromEntries(
      [...new FormData(form).entries()]
        .filter(([k]) => !skipPayloadKeys.has(k))
        .map(([k, v]) => [k, typeof v === 'string' ? v : '']),
    ) as Record<string, string>;
    return {
      ...entries,
      instagram: entries.instagram ?? '',
      linkedin: entries.linkedin ?? '',
    };
  };

  const parseErrorMessage = async (res: Response): Promise<string | null> => {
    const body = (await res.json().catch(() => null)) as { message?: string } | null;
    const msg = body?.message?.trim();
    return msg && msg.length > 0 ? msg : null;
  };

  const isWaitlistFieldName = (v: string): v is WaitlistFormFieldName =>
    (WAITLIST_FORM_FIELD_NAMES as readonly string[]).includes(v);

  const initWaitlistRoot = (root: HTMLElement) => {
    if (root.dataset.waitlistBound === '1') return;
    root.dataset.waitlistBound = '1';

    const form = root.querySelector<HTMLFormElement>('[data-waitlist-form]');
    const formPanel = root.querySelector<HTMLElement>('[data-waitlist-form-panel]');
    const successPanel = root.querySelector<HTMLElement>('[data-waitlist-success-panel]');
    const successHeadline = root.querySelector<HTMLElement>('[data-waitlist-success-headline]');
    const successClose = root.querySelector<HTMLButtonElement>('[data-waitlist-success-close]');
    const statusEl = root.querySelector<HTMLElement>('[data-waitlist-status]');
    const submitBtn = root.querySelector<HTMLButtonElement>('[data-waitlist-submit-btn]');
    const submitLabel = root.querySelector<HTMLElement>('[data-waitlist-submit-label]');
    const spinner = root.querySelector<SVGElement>('[data-waitlist-spinner]');
    const phoneInput = root.querySelector<HTMLInputElement>('[data-waitlist-field="phone"]');
    if (
      !form ||
      !formPanel ||
      !successPanel ||
      !successHeadline ||
      !successClose ||
      !statusEl ||
      !submitBtn ||
      !submitLabel ||
      !phoneInput
    )
      return;

    const sending = root.dataset.waitlistSending ?? '';
    const errorMsg = root.dataset.waitlistError ?? '';
    const sendFailedMsg = root.dataset.waitlistSendFailed ?? errorMsg;
    const defaultBtn = root.dataset.waitlistButton ?? '';
    const lang = root.dataset.lang === 'es' ? 'es' : 'en';

    const validationMsgs = JSON.parse(root.dataset.waitlistValidation ?? '{}') as ValidationMsgs;
    const successInsideBefore = root.dataset.successInsideBefore ?? '';
    const successInsideAfter = root.dataset.successInsideAfter ?? '';

    const fieldSchemas = createWaitlistFormFieldSchemas(validationMsgs);
    const formSchema = createWaitlistFormSchema(validationMsgs);

    const phoneController = PhoneController.attach(phoneInput, lang);

    const setSubmitVisual = (state: 'idle' | 'sending') => {
      submitBtn.dataset.status = state;
      submitBtn.dataset.busy = state === 'sending' ? 'true' : 'false';
      submitBtn.disabled = state === 'sending';
      submitLabel.textContent = state === 'sending' ? sending : defaultBtn;
      spinner?.classList.toggle('hidden', state !== 'sending');
      if (state === 'sending') document.body.dataset.waitlistFormStatus = 'sending';
      else delete document.body.dataset.waitlistFormStatus;
    };

    const setFieldA11y = (el: HTMLElement, invalid: boolean, errId: string | null) => {
      el.setAttribute('aria-invalid', invalid ? 'true' : 'false');
      if (invalid && errId) el.setAttribute('aria-describedby', errId);
      else el.removeAttribute('aria-describedby');
    };

    const clearControlVisual = (el: HTMLElement) => {
      el.classList.remove(
        'input-error',
        'input-success',
        'select-error',
        'select-success',
        'textarea-error',
        'textarea-success',
        'checkbox-error',
        'checkbox-success',
        'ring-2',
        'ring-error',
        'ring-success',
        'ring-offset-2',
      );
    };

    const applyControlError = (el: HTMLElement) => {
      if (el instanceof HTMLInputElement && el.type === 'checkbox') {
        el.classList.add('ring-2', 'ring-error', 'ring-offset-2');
        return;
      }
      if (el instanceof HTMLSelectElement) {
        el.classList.add('select-error');
        return;
      }
      if (el instanceof HTMLTextAreaElement) {
        el.classList.add('textarea-error');
        return;
      }
      if (el instanceof HTMLInputElement) {
        el.classList.add('input-error');
      }
    };

    const applyControlSuccess = (el: HTMLElement) => {
      if (el instanceof HTMLInputElement && el.type === 'checkbox') {
        el.classList.add('ring-2', 'ring-success', 'ring-offset-2');
        return;
      }
      if (el instanceof HTMLSelectElement) {
        el.classList.add('select-success');
        return;
      }
      if (el instanceof HTMLTextAreaElement) {
        el.classList.add('textarea-success');
        return;
      }
      if (el instanceof HTMLInputElement) {
        el.classList.add('input-success');
      }
    };

    const showFieldError = (field: WaitlistFormFieldName | 'terms', message: string) => {
      const errEl = root.querySelector<HTMLElement>(`[data-waitlist-err="${field}"]`);
      const control = root.querySelector<HTMLElement>(`[data-waitlist-field="${field}"]`);
      if (!errEl || !control) return;
      clearControlVisual(control);
      applyControlError(control);
      errEl.textContent = message;
      errEl.dataset.visible = 'true';
      setFieldA11y(control, true, errEl.id || null);
    };

    const showFieldSuccess = (field: WaitlistFormFieldName | 'terms') => {
      const errEl = root.querySelector<HTMLElement>(`[data-waitlist-err="${field}"]`);
      const control = root.querySelector<HTMLElement>(`[data-waitlist-field="${field}"]`);
      if (!control) return;
      clearControlVisual(control);
      applyControlSuccess(control);
      if (errEl) {
        errEl.textContent = '';
        errEl.dataset.visible = 'false';
      }
      setFieldA11y(control, false, null);
    };

    const clearFieldError = (field: WaitlistFormFieldName | 'terms') => {
      const errEl = root.querySelector<HTMLElement>(`[data-waitlist-err="${field}"]`);
      const control = root.querySelector<HTMLElement>(`[data-waitlist-field="${field}"]`);
      if (!errEl || !control) return;
      clearControlVisual(control);
      errEl.textContent = '';
      errEl.dataset.visible = 'false';
      setFieldA11y(control, false, null);
    };

    const clearAllFieldErrors = () => {
      WAITLIST_FORM_FIELD_NAMES.map((f) => clearFieldError(f));
      clearFieldError('terms');
    };

    const readControlValue = (field: WaitlistFormFieldName | 'terms'): string => {
      const el = root.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(
        `[data-waitlist-field="${field}"]`,
      );
      return el?.value ?? '';
    };

    /** Zod sobre `fullNumber` + validación libphonenumber vía PhoneController. */
    const validatePhoneWithController = (withSuccessFeedback: boolean): boolean => {
      const zod = fieldSchemas.phone.safeParse(phoneController.fullNumber);
      if (!zod.success) {
        showFieldError('phone', zod.error.issues[0]?.message ?? errorMsg);
        return false;
      }
      if (!phoneController.isValid()) {
        showFieldError('phone', validationMsgs.phoneInvalid);
        return false;
      }
      if (withSuccessFeedback) showFieldSuccess('phone');
      else clearFieldError('phone');
      return true;
    };

    const validateFieldOnBlur = (field: WaitlistFormFieldName) => {
      if (field === 'phone') {
        validatePhoneWithController(true);
        return;
      }
      const raw = readControlValue(field);
      const parsed = fieldSchemas[field].safeParse(raw);
      if (parsed.success) showFieldSuccess(field);
      else showFieldError(field, parsed.error.issues[0]?.message ?? errorMsg);
    };

    const validateTerms = (): boolean => {
      const cb = root.querySelector<HTMLInputElement>('[data-waitlist-field="terms"]');
      if (!cb) return false;
      if (cb.checked) {
        clearFieldError('terms');
        return true;
      }
      showFieldError('terms', validationMsgs.termsRequired);
      return false;
    };

    WAITLIST_FORM_FIELD_NAMES.map((name) => {
      const el = root.querySelector(`[data-waitlist-field="${name}"]`);
      el?.addEventListener('blur', () => validateFieldOnBlur(name));
      el?.addEventListener('focus', () => clearFieldError(name));
    });

    const termsEl = root.querySelector('[data-waitlist-field="terms"]');
    termsEl?.addEventListener('change', () => {
      const cb = termsEl as HTMLInputElement;
      if (cb.checked) showFieldSuccess('terms');
      else clearFieldError('terms');
    });
    termsEl?.addEventListener('blur', () => {
      const cb = termsEl as HTMLInputElement;
      if (!cb.checked) showFieldError('terms', validationMsgs.termsRequired);
      else showFieldSuccess('terms');
    });

    const validateAllFields = (): boolean => {
      clearAllFieldErrors();
      const invalidFields = WAITLIST_FORM_FIELD_NAMES.filter((name) => {
        if (name === 'phone') return !validatePhoneWithController(false);
        const raw = readControlValue(name);
        const parsed = fieldSchemas[name].safeParse(raw);
        if (!parsed.success) {
          showFieldError(name, parsed.error.issues[0]?.message ?? errorMsg);
          return true;
        }
        return false;
      });
      const termsOk = validateTerms();
      return invalidFields.length === 0 && termsOk;
    };

    const showSuccessView = (firstName: string) => {
      const safeName = firstName.trim() || (lang === 'es' ? 'sloworker' : 'friend');
      successHeadline.textContent = `${successInsideBefore} ${safeName}${successInsideAfter}`;
      formPanel.dataset.state = 'hidden';
      successPanel.dataset.state = 'visible';
      successPanel.setAttribute('aria-hidden', 'false');
      statusEl.dataset.status = 'success';
      statusEl.textContent = '';
      setSubmitVisual('idle');
    };

    const resetToFormView = () => {
      form.reset();
      phoneController.clear();
      clearAllFieldErrors();
      formPanel.dataset.state = 'visible';
      successPanel.dataset.state = 'hidden';
      successPanel.setAttribute('aria-hidden', 'true');
      statusEl.dataset.status = 'idle';
      statusEl.textContent = '';
      setSubmitVisual('idle');
    };

    successClose.addEventListener('click', () => {
      resetToFormView();
      document.getElementById('close-waitlist')?.click();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validateAllFields()) {
        const firstInvalid = root.querySelector<HTMLElement>('[aria-invalid="true"]');
        firstInvalid?.focus();
        return;
      }

      const payloadStrings = payloadFromForm(form);
      payloadStrings.phone = phoneController.fullNumber;

      const parsed = formSchema.safeParse(payloadStrings);

      if (!parsed.success) {
        parsed.error.issues.forEach((issue) => {
          const key = issue.path[0];
          if (typeof key === 'string' && isWaitlistFieldName(key)) showFieldError(key, issue.message);
        });
        return;
      }

      if (!phoneController.isValid()) {
        showFieldError('phone', validationMsgs.phoneInvalid);
        phoneInput.focus();
        return;
      }

      const apiReady = waitlistCreateBodySchema.safeParse(parsed.data);
      if (!apiReady.success) {
        statusEl.dataset.status = 'error';
        statusEl.textContent = errorMsg;
        return;
      }

      statusEl.dataset.status = 'sending';
      statusEl.textContent = '';
      setSubmitVisual('sending');

      const apiBody = {
        ...apiReady.data,
        instagram: apiReady.data.instagram ?? '',
        linkedin: apiReady.data.linkedin ?? '',
      };

      const res = await fetch('/api/waitlist/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(apiBody),
      }).catch(() => null);

      if (res === null) {
        statusEl.dataset.status = 'error';
        statusEl.textContent = sendFailedMsg;
        setSubmitVisual('idle');
        return;
      }

      if (!res.ok) {
        const serverMessage = await parseErrorMessage(res);
        statusEl.dataset.status = 'error';
        statusEl.textContent = serverMessage ?? sendFailedMsg;
        setSubmitVisual('idle');
        return;
      }

      const firstName = parsed.data.firstName;
      form.reset();
      phoneController.clear();
      clearAllFieldErrors();
      showSuccessView(firstName);
    });
  };

  const bindWaitlistTermsDialog = (root: HTMLElement) => {
    if (root.dataset.waitlistTermsDialogBound === '1') return;
    const dialog = root.querySelector('dialog.terms-policy-dialog');
    if (!(dialog instanceof HTMLDialogElement)) return;
    root.dataset.waitlistTermsDialogBound = '1';

    const openBtn = root.querySelector<HTMLButtonElement>('[data-open-waitlist-terms-dialog]');
    openBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      dialog.showModal();
    });

    dialog.querySelectorAll<HTMLButtonElement>('[data-close-waitlist-terms-dialog]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.close());
    });

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  };

  const boot = () => {
    [...document.querySelectorAll<HTMLElement>('.waitlist-form-root')].map((el) => {
      initWaitlistRoot(el);
      bindWaitlistTermsDialog(el);
    });
  };

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
