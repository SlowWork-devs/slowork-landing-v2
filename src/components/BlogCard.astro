---
import { Image } from 'astro:assets';
import type { LocalizedBlogPost, ApiLang } from '@/lib/api-service';
import { formatBlogCreationDate } from '@/lib/blog-display';
import { BLOG_IMAGE_CLOUDFRONT_HOST, SITE_TITLE } from '@/consts';

interface Props {
  post: LocalizedBlogPost;
  lang: ApiLang;
}

const { post, lang } = Astro.props;
const postUrl = `/${lang}/blog/${post.slug}/`;
const cta = lang === 'es' ? 'Leer más' : 'Read more';
const aria = lang === 'es' ? `Abrir post: ${post.title}` : `Open post: ${post.title}`;

const cloudFrontImage =
  post.image_url && /^https?:\/\//i.test(post.image_url)
    ? (() => {
        try {
          return new URL(post.image_url).hostname === BLOG_IMAGE_CLOUDFRONT_HOST ? post.image_url : null;
        } catch {
          return null;
        }
      })()
    : null;

const displayDate = post.date_published || post.creation_date;
const formattedDate = formatBlogCreationDate(displayDate, lang);
---

<a
  href={postUrl}
  aria-label={aria}
  class="group flex h-full min-h-0 w-full min-w-0 flex-1 flex-col overflow-hidden rounded-2xl bg-white text-left no-underline shadow-sm border border-primary/10 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-white touch-manipulation"
>
  {/*
    Caja de ratio fija + imagen en absolute: el tamaño intrínseco del remoto no puede reventar la altura de la tarjeta.
  */}
  <div class="relative aspect-video w-full shrink-0 overflow-hidden bg-primary/5">
    {cloudFrontImage ? (
      <Image
        src={cloudFrontImage}
        alt={post.title || SITE_TITLE}
        inferSize
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : post.image_url ? (
      <img
        src={post.image_url}
        alt={post.title || SITE_TITLE}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : (
      <div class="absolute inset-0" aria-hidden="true" />
    )}
  </div>

  <div class="flex min-h-0 min-w-0 flex-1 flex-col p-5 sm:p-6">
    <p class="mb-2 text-sm capitalize text-primary/70">
      {formattedDate}
    </p>
    <h2 class="mb-3 font-heading text-xl font-bold leading-snug text-primary line-clamp-2 sm:text-2xl">
      {post.title}
    </h2>

    {/*
      line-clamp no aplica bien a HTML con <p>/<hr>/<img>; max-height + overflow + márgenes a cero evitan huecos gigantes.
    */}
    {post.excerpt ? (
      <div
        class="mb-4 min-h-0 max-h-21 w-full min-w-0 overflow-hidden text-sm leading-relaxed text-primary/80 [&_a]:font-medium [&_a]:text-primary [&_a]:no-underline [&_blockquote]:my-0 [&_div]:my-0 [&_h1]:my-0 [&_h2]:my-0 [&_h3]:my-0 [&_h4]:my-0 [&_hr]:hidden [&_img]:hidden [&_li]:my-0 [&_ol]:my-0 [&_p]:my-0 [&_pre]:my-0 [&_ul]:my-0"
        set:html={post.excerpt}
      />
    ) : (
      <div
        class="mb-4 min-h-0 max-h-21 w-full min-w-0 overflow-hidden text-sm leading-relaxed text-primary/80 [&_a]:font-medium [&_a]:text-primary [&_a]:no-underline [&_blockquote]:my-0 [&_div]:my-0 [&_h1]:my-0 [&_h2]:my-0 [&_h3]:my-0 [&_h4]:my-0 [&_hr]:hidden [&_img]:hidden [&_li]:my-0 [&_ol]:my-0 [&_p]:my-0 [&_pre]:my-0 [&_ul]:my-0"
        set:html={post.content}
      />
    )}

    <span class="mt-auto inline-flex items-center gap-2 pt-1 text-sm font-bold text-primary transition-colors group-hover:text-secondary sm:text-base">
      {cta}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</a>
