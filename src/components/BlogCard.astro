---
import { Image } from 'astro:assets';
import type { LocalizedBlogPost, ApiLang } from '@/lib/api-service';
import { formatBlogCreationDate } from '@/lib/blog-display';
import { BLOG_IMAGE_CLOUDFRONT_HOST, SITE_TITLE } from '@/consts';

interface Props {
  post: LocalizedBlogPost;
  lang: ApiLang;
}

const { post, lang } = Astro.props;
const postUrl = `/${lang}/blog/${post.slug}/`;
const cta = lang === 'es' ? 'Leer más' : 'Read more';
const aria = lang === 'es' ? `Abrir post: ${post.title}` : `Open post: ${post.title}`;

const cloudFrontImage =
  post.image_url && /^https?:\/\//i.test(post.image_url)
    ? (() => {
        try {
          return new URL(post.image_url).hostname === BLOG_IMAGE_CLOUDFRONT_HOST ? post.image_url : null;
        } catch {
          return null;
        }
      })()
    : null;

const displayDate = post.date_published || post.creation_date;
const formattedDate = formatBlogCreationDate(displayDate, lang);
---

<a
  href={postUrl}
  aria-label={aria}
  class="group block h-full min-h-[280px] w-full rounded-2xl overflow-hidden bg-white border border-primary/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 ease-out text-left no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-white touch-manipulation"
>
  <div class="aspect-video w-full overflow-hidden bg-primary/5">
    {cloudFrontImage ? (
      <Image
        src={cloudFrontImage}
        alt={post.title || SITE_TITLE}
        inferSize
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : post.image_url ? (
      <img
        src={post.image_url}
        alt={post.title || SITE_TITLE}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full" aria-hidden="true" />
    )}
  </div>

  <div class="p-5 sm:p-6 flex flex-col grow">
    <p class="text-sm text-primary/70 mb-2 capitalize">
      {formattedDate}
    </p>
    <h2 class="font-heading font-bold text-primary text-xl sm:text-2xl leading-snug mb-3 line-clamp-2">
      {post.title}
    </h2>

    {post.excerpt ? (
      <div
        class="prose prose-sm prose-headings:font-heading prose-p:mb-2 prose-p:last:mb-0 prose-a:no-underline prose-a:font-medium prose-a:text-primary w-full max-w-none text-primary/80 leading-relaxed mb-4 grow line-clamp-3"
        set:html={post.excerpt}
      />
    ) : (
      <div
        class="prose prose-sm prose-headings:font-heading prose-p:mb-3 prose-a:no-underline prose-a:font-medium prose-a:text-primary w-full max-w-none text-primary/80 leading-relaxed mb-4 grow line-clamp-3"
        set:html={post.content}
      />
    )}

    <span class="inline-flex items-center gap-2 font-bold text-primary text-sm sm:text-base group-hover:text-secondary transition-colors">
      {cta}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </div>
</a>
