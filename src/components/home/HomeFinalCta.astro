---
import Button from '@/components/ui/Button.astro';
import type { SupportedLang } from '@/lib/seo';
import { homeFinalCtaCopy } from '@/lib/homeContent';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const copy = homeFinalCtaCopy(lang);
---

<section
  id="waitlist-cta"
  class="home-final-cta-bleed relative z-0 -mt-20 max-sm:-mt-16 rounded-t-[40px] border-t border-white/20 py-14 md:py-20"
>
  <div
    class="home-reveal reveal-depth mx-auto max-w-4xl px-4 text-center"
    data-home-reveal
  >
    <h2 class="font-heading text-3xl font-bold text-primary md:text-5xl">
      {copy.title}
    </h2>
    <div class="mt-10 flex justify-center">
      <Button
        variant="primary"
        type="button"
        openWaitlist
        class="px-8 py-3.5 shadow-xl md:min-h-14 md:px-10 md:text-lg"
      >
        {copy.waitlist}
      </Button>
    </div>
  </div>
</section>

<style>
  /* Cristal + tinte oklab (primary / landing / secondary) alineado con la sección anterior. */
  .home-final-cta-bleed {
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    background-image: linear-gradient(
      to bottom,
      color-mix(in oklab, var(--color-primary) 14%, white 86% / 0.78) 0%,
      color-mix(in oklab, var(--color-bg-landing) 62%, var(--color-secondary) 38% / 0.9) 46%,
      color-mix(in oklab, var(--color-bg-landing) 40%, var(--color-secondary) 60%) 100%
    );
  }
</style>
