---
import { getImage } from 'astro:assets';

import Button from '@/components/ui/Button.astro';
import type { SupportedLang } from '@/lib/seo';
import { HOME_MEDIA, homeHeroCopy } from '@/lib/homeContent';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const copy = homeHeroCopy(lang);
const blogHref = `/${lang}/blog/`;

const heroPoster = await getImage({
  src: HOME_MEDIA.videoPoster,
  width: 1920,
  format: 'webp',
  quality: 82,
});
---

<section id="hero" class="relative z-10 w-full min-h-[95vh] overflow-hidden">
  <!-- Máscara lineal en el último ~15%: el vídeo se funde con la sección siguiente (section bleed). -->
  <div class="hero-media-fade absolute inset-0 z-0">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      width="1920"
      height="1080"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster={heroPoster.src}
    >
      <source src={HOME_MEDIA.videoSrc} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-primary/45"></div>
  </div>

  <div class="relative z-10 flex min-h-[95vh] flex-col items-center justify-center px-6 pb-16 pt-32 text-center text-white md:pt-28">
    <h1
      class="mt-2 max-w-4xl font-heading text-[clamp(1.35rem,4vw+0.5rem,3.75rem)] font-bold leading-tight text-secondary md:mb-2 text-center flex flex-wrap justify-center items-center gap-x-2"
    >
      <span>{copy.line1}</span>
      <span class="whitespace-nowrap flex items-center gap-x-2">
        <span
          id="hero-first"
          class="inline-block font-bold text-soft-blue rotator-text"
        ></span>
        <span>{copy.line1b}</span>
      </span>
    </h1>
    <h2
      class="mt-3 flex min-h-[3.5rem] items-center justify-center px-2 text-[clamp(1.2rem,3vw+0.5rem,3rem)] font-light text-secondary md:min-h-[4rem]"
    >
      <span id="hero-phrase" class="inline-block rotator-text"></span>
    </h2>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <Button
        variant="primary"
        type="button"
        openWaitlist
        class="waitlist-landing-hook text-center"
      >
        {copy.ctaWaitlist}
      </Button>
      <Button variant="glass" href={blogHref} class="text-center font-bold">
        {copy.ctaBlog}
      </Button>
    </div>
    <p class="mt-4 max-w-2xl px-4 text-[11px] italic text-white/80 md:text-sm">{copy.italic}</p>
  </div>
</section>

<script define:vars={{ combinations: copy.combinations }}>
  let heroRotatorCleanup;

  document.addEventListener('astro:page-load', () => {
    if (typeof heroRotatorCleanup === 'function') heroRotatorCleanup();

    const firstEl = document.getElementById('hero-first');
    const phraseEl = document.getElementById('hero-phrase');

    if (!firstEl || !phraseEl || !combinations?.length) {
      heroRotatorCleanup = undefined;
      return;
    }

    const pendingTimeouts = [];
    const schedule = (fn, ms) => {
      const id = window.setTimeout(fn, ms);
      pendingTimeouts.push(id);
      return id;
    };

    let intervalFirstId;
    let intervalPhraseId;
    let phraseDelayId;

    const clearAll = () => {
      pendingTimeouts.forEach((tid) => window.clearTimeout(tid));
      pendingTimeouts.length = 0;
      if (intervalFirstId !== undefined) window.clearInterval(intervalFirstId);
      if (intervalPhraseId !== undefined) window.clearInterval(intervalPhraseId);
      if (phraseDelayId !== undefined) window.clearTimeout(phraseDelayId);
      intervalFirstId = undefined;
      intervalPhraseId = undefined;
      phraseDelayId = undefined;
    };

    heroRotatorCleanup = clearAll;

    const transitionDuration = 1500;
    let currentIndexFirst = 0;
    let currentIndexPhrase = 0;

    const animateChange = (el, newText) => {
      if (!el) return;
      el.classList.add('word-exit');
      schedule(() => {
        el.textContent = newText;
        el.classList.remove('word-exit');
        el.classList.add('word-enter');
        void el.offsetWidth;
        el.classList.remove('word-enter');
      }, transitionDuration);
    };

    const updateFirst = () => {
      currentIndexFirst = (currentIndexFirst + 1) % combinations.length;
      animateChange(document.getElementById('hero-first'), combinations[currentIndexFirst].first);
    };

    const updatePhrase = () => {
      currentIndexPhrase = (currentIndexPhrase + 1) % combinations.length;
      animateChange(document.getElementById('hero-phrase'), combinations[currentIndexPhrase].phrase);
    };

    const initialCombo = combinations[0];
    firstEl.textContent = initialCombo.first;
    phraseEl.textContent = initialCombo.phrase;

    intervalFirstId = window.setInterval(updateFirst, 7000);

    phraseDelayId = window.setTimeout(() => {
      phraseDelayId = undefined;
      intervalPhraseId = window.setInterval(updatePhrase, 8500);
      updatePhrase();
    }, 3000);
  });
</script>

<style>
  .hero-media-fade {
    mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 85%, transparent 100%);
    mask-size: 100% 100%;
    -webkit-mask-size: 100% 100%;
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .rotator-text {
    will-change: transform, opacity, filter;
    transition: opacity 1.5s cubic-bezier(0.4, 0, 0.2, 1), 
                transform 1.5s cubic-bezier(0.4, 0, 0.2, 1), 
                filter 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 1;
    transform: translateY(0);
    filter: blur(0px);
  }

  /* Salida: desvanecer hacia arriba con blur */
  .word-exit {
    opacity: 0 !important;
    transform: translateY(-8px) !important;
    filter: blur(6px) !important;
  }

  /* Entrada: emerger desde abajo (se aplica sin transición para preparar la posición) */
  .word-enter {
    transition: none !important;
    opacity: 0 !important;
    transform: translateY(8px) !important;
    filter: blur(6px) !important;
  }
</style>
