---
import type { SupportedLang } from '@/lib/seo';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const label = lang === 'es' ? 'Únete a la lista' : 'Join the waitlist!';
---

<div
  class="fixed bottom-6 right-4 z-[60] md:bottom-8 md:right-6 lg:bottom-10 lg:right-8"
  aria-hidden="false"
>
  <button
    type="button"
    data-open-waitlist
    class="waitlist-landing-hook btn btn-waitlist-floating flex gap-2"
  >
    <span class="text-lg leading-none">╰(*°▽°*)╯</span>
    {label}
  </button>
</div>
