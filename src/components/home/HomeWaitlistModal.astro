---
import type { SupportedLang } from '@/lib/seo';
import WaitlistForm from '@/components/features/WaitlistForm.astro';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
---

<div id="modal-overlay" class="fixed inset-0 z-[100] hidden bg-primary/45 backdrop-blur-sm"></div>
<div
  id="waitlist-modal"
  class="fixed inset-0 z-[110] hidden grid place-items-center p-3 pt-[max(0.75rem,env(safe-area-inset-top))] pb-[max(0.75rem,env(safe-area-inset-bottom))] sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-label="Waitlist"
>
  <div
    class="flex min-h-0 w-full max-h-[min(88dvh,900px)] max-w-5xl flex-col overflow-hidden rounded-2xl border border-primary/10 bg-light-green shadow-2xl sm:max-h-[min(92vh,900px)]"
  >
    <div class="flex shrink-0 items-center justify-between gap-3 border-b border-primary/10 px-4 py-3 sm:p-5">
      <h3 class="min-w-0 flex-1 font-heading text-base font-bold leading-snug text-primary sm:text-lg md:text-xl">
        {lang === 'es' ? 'Únete a la waitlist' : 'Join the waitlist'}
      </h3>
      <button
        type="button"
        id="close-waitlist"
        class="grid shrink-0 min-h-11 min-w-11 place-items-center text-primary/70 hover:text-primary"
        aria-label={lang === 'es' ? 'Cerrar' : 'Close'}
      >
        ✕
      </button>
    </div>
    <div
      class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto overscroll-y-contain px-4 pb-[max(1rem,env(safe-area-inset-bottom))] pt-4 sm:px-5 sm:pb-[max(1.25rem,env(safe-area-inset-bottom))] sm:pt-5"
    >
      <WaitlistForm lang={lang} layout="minimal" />
    </div>
  </div>
</div>
