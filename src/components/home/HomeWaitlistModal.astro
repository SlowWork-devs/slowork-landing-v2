---
import type { SupportedLang } from '@/lib/seo';
import WaitlistForm from '@/components/features/WaitlistForm.astro';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
---

<div id="modal-overlay" class="fixed inset-0 z-[100] hidden bg-black/50 backdrop-blur-sm"></div>
<div
  id="waitlist-modal"
  class="fixed inset-0 z-[110] hidden grid place-items-center p-4 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-label="Waitlist"
>
  <div class="flex max-h-[min(92vh,880px)] w-full max-w-2xl flex-col overflow-hidden rounded-2xl border border-primary/10 bg-white shadow-2xl">
    <div class="flex shrink-0 items-center justify-between border-b border-primary/10 p-4 sm:p-5">
      <h3 class="font-heading text-lg font-bold text-primary sm:text-xl">
        {lang === 'es' ? 'Únete a la waitlist' : 'Join the waitlist'}
      </h3>
      <button
        type="button"
        id="close-waitlist"
        class="grid min-h-11 min-w-11 place-items-center text-primary/70 hover:text-primary"
        aria-label={lang === 'es' ? 'Cerrar' : 'Close'}
      >
        ✕
      </button>
    </div>
    <div class="min-h-0 overflow-y-auto p-4 sm:p-6">
      <WaitlistForm lang={lang} layout="minimal" />
    </div>
  </div>
</div>
