---
import Logo from '@/components/Logo.astro';
import SocialShareBar from '@/components/ui/SocialShareBar.astro';
import { Image } from 'astro:assets';
import menuBg from '@/assets/menu-background.webp';
import { homeNavCopy } from '@/lib/homeContent';
import { isSupportedLang, type SupportedLang } from '@/lib/seo';

const { language, langHrefEs, langHrefEn } = Astro.props;
const lang: SupportedLang = isSupportedLang(language) ? language : 'es';
const nav = homeNavCopy(lang);
const blogHref = `/${lang}/blog/`;
const aboutHref = `/${lang}/about-us/`;
const impactHref = `/${lang}/impact-program/`;
const waitlistCtaHref = `/${lang}/#waitlist-cta`;

const mainNavItems = [
  { href: blogHref, label: nav.blog },
  { href: aboutHref, label: nav.about },
  { href: impactHref, label: nav.impact },
] as const;

// Home: cabecera transparente al inicio
const isHome = Astro.url.pathname === '/es/' || Astro.url.pathname === '/en/' || Astro.url.pathname === '/es' || Astro.url.pathname === '/en' || Astro.url.pathname === '/';
const initialClasses = isHome 
  ? "py-4 md:py-6 text-bg-landing bg-bg-landing/12 backdrop-blur-sm border-b border-bg-landing/25" 
  : "header-scrolled text-primary";
---

<header id="main-header" class={`fixed top-0 left-0 w-full z-100 transition-all duration-500 ${initialClasses}`} data-is-home={isHome ? "true" : "false"}>
  <nav class="max-w-7xl mx-auto px-6 flex justify-between items-center gap-4 min-h-12">
    <div class="shrink-0 flex items-center">
      <Logo language={lang} class="text-current" />
    </div>

    <div class="flex items-center shrink-0 gap-2 md:gap-6">
      <div class="hidden md:flex items-center gap-6">
        {mainNavItems.map((item) => (
          <a href={item.href} class="text-sm font-heading font-bold hover:opacity-80 transition-opacity">{item.label}</a>
        ))}
      </div>

      <div class="hidden md:flex items-center gap-1 text-xs font-bold border-l border-current/20 pl-4">
        <a href={langHrefEs} class="min-w-10 min-h-10 flex items-center justify-center rounded-lg hover:bg-current/5 transition-colors" aria-current={lang === 'es' ? 'page' : undefined}>{nav.langLabelEs}</a>
        <span class="opacity-30">|</span>
        <a href={langHrefEn} class="min-w-10 min-h-10 flex items-center justify-center rounded-lg hover:bg-current/5 transition-colors" aria-current={lang === 'en' ? 'page' : undefined}>{nav.langLabelEn}</a>
      </div>

      <button
        type="button"
        data-open-waitlist
        class="btn btn-primary hidden font-heading text-sm md:flex min-h-12 whitespace-nowrap px-6 py-3"
      >
        {nav.join}
      </button>

      <button 
        id="menu-button" 
        class="md:hidden flex items-center justify-center hover:opacity-80 transition-opacity min-w-12 min-h-12 p-3 -m-2 rounded-lg touch-manipulation"
        aria-label={nav.menu}
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Drawer Overlay -->
<div
  id="drawer-overlay"
  class="fixed inset-0 z-105 hidden bg-primary/20 backdrop-blur-sm md:hidden"
  data-drawer-open="false"
  aria-hidden="true"
></div>

<!-- Mobile Drawer -->
<div
  id="mobile-drawer"
  class="fixed inset-y-0 right-0 z-110 hidden w-full max-w-sm translate-x-full transform flex-col overflow-hidden shadow-2xl transition-transform duration-300 md:hidden"
  data-drawer-open="false"
  role="dialog"
  aria-modal="true"
  aria-label={nav.mobileDrawerAriaLabel}
>
  <Image
    src={menuBg}
    alt=""
    class="absolute inset-0 w-full h-full object-cover -z-20"
    loading="lazy"
    fetchpriority="low"
    decoding="async"
  />
  <div class="absolute inset-0 bg-light-green/75 backdrop-blur-md -z-8"></div>

  <div class="flex justify-between items-center px-6 py-4 min-h-[80px]">
    <Logo language={lang} />
    <button 
      id="close-drawer-button" 
      class="flex items-center justify-center text-primary hover:opacity-80 transition-opacity min-w-12 min-h-12 p-3 -m-2 rounded-lg touch-manipulation"
      aria-label={nav.close}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex-1 flex flex-col px-6 py-8 overflow-y-auto">
    <nav class="mb-8 flex flex-col gap-6 text-right">
      {mainNavItems.map((item) => (
        <a href={item.href} class="text-2xl font-heading font-bold text-primary hover:text-primary/70 transition-colors">{item.label}</a>
      ))}
    </nav>

    <div class="mb-10 w-full">
      <SocialShareBar language={lang} variant="drawer" />
    </div>

    <div class="mt-auto flex flex-col items-center gap-8">
      <div class="flex items-center gap-2 text-sm font-bold text-primary">
        <a href={langHrefEs} class={`min-w-12 min-h-12 flex items-center justify-center rounded-lg transition-colors ${lang === 'es' ? 'bg-primary/10' : 'hover:bg-primary/5'}`} aria-current={lang === 'es' ? 'page' : undefined}>{nav.langLabelEs}</a>
        <span class="opacity-30">|</span>
        <a href={langHrefEn} class={`min-w-12 min-h-12 flex items-center justify-center rounded-lg transition-colors ${lang === 'en' ? 'bg-primary/10' : 'hover:bg-primary/5'}`} aria-current={lang === 'en' ? 'page' : undefined}>{nav.langLabelEn}</a>
      </div>

      <a
        href={waitlistCtaHref}
        class="inline-flex w-full min-h-3.75rem items-center justify-center rounded-full bg-primary px-4 py-4 text-center text-sm font-heading font-bold leading-snug text-secondary shadow-xl ring-2 ring-secondary/60 transition-all duration-300 hover:scale-[1.03] hover:shadow-[0_0_28px_rgba(34,197,94,0.1)] active:scale-[0.99] touch-manipulation sm:px-6 sm:text-base"
      >
        {nav.join}
      </a>
    </div>
  </div>
</div>

<script>
  let closeMenuTimeoutId: number | undefined;

  const clearCloseMenuTimeout = () => {
    if (closeMenuTimeoutId === undefined) return;
    window.clearTimeout(closeMenuTimeoutId);
    closeMenuTimeoutId = undefined;
  };

  const setMenuOpen = (open: boolean) => {
    if (open) document.body.setAttribute('data-menu-open', 'true');
    else document.body.removeAttribute('data-menu-open');
  };

  /** Cierra el menú al momento (sin animación), por si Astro deja el drawer en mal estado. */
  const closeMenuDirectly = () => {
    clearCloseMenuTimeout();
    setMenuOpen(false);
    document.body.style.overflow = '';
    const drawerOverlay = document.getElementById('drawer-overlay');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const menuButton = document.getElementById('menu-button');
    drawerOverlay?.classList.add('hidden');
    if (drawerOverlay) drawerOverlay.dataset.drawerOpen = 'false';
    mobileDrawer?.classList.add('hidden', 'translate-x-full');
    mobileDrawer?.classList.remove('flex');
    if (mobileDrawer) mobileDrawer.dataset.drawerOpen = 'false';
    menuButton?.setAttribute('aria-expanded', 'false');
  };

  const bindMobileMenu = () => {
    const menuButton = document.getElementById('menu-button');
    const closeButton = document.getElementById('close-drawer-button');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const drawerOverlay = document.getElementById('drawer-overlay');
    if (!menuButton || !closeButton || !mobileDrawer || !drawerOverlay) return () => {};

    const openMenu = () => {
      setMenuOpen(true);
      drawerOverlay.dataset.drawerOpen = 'true';
      mobileDrawer.dataset.drawerOpen = 'true';
      mobileDrawer.classList.remove('hidden');
      mobileDrawer.classList.add('flex');
      drawerOverlay.classList.remove('hidden');
      void mobileDrawer.offsetWidth;
      mobileDrawer.classList.remove('translate-x-full');
      menuButton.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      setMenuOpen(false);
      drawerOverlay.dataset.drawerOpen = 'false';
      mobileDrawer.classList.add('translate-x-full');
      menuButton.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      clearCloseMenuTimeout();
      closeMenuTimeoutId = window.setTimeout(() => {
        mobileDrawer.dataset.drawerOpen = 'false';
        mobileDrawer.classList.add('hidden');
        mobileDrawer.classList.remove('flex');
        drawerOverlay.classList.add('hidden');
        closeMenuTimeoutId = undefined;
      }, 300);
    };

    const onDrawerLinkClick = (e: MouseEvent) => {
      const target = e.target as HTMLElement | null;
      const anchor = target?.closest?.('a[href]');
      if (anchor && mobileDrawer.contains(anchor)) closeMenu();
    };

    menuButton.addEventListener('click', openMenu);
    closeButton.addEventListener('click', closeMenu);
    drawerOverlay.addEventListener('click', closeMenu);
    mobileDrawer.addEventListener('click', onDrawerLinkClick);

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !mobileDrawer.classList.contains('translate-x-full')) closeMenu();
    };
    document.addEventListener('keydown', onKeydown);

    return () => {
      clearCloseMenuTimeout();
      menuButton.removeEventListener('click', openMenu);
      closeButton.removeEventListener('click', closeMenu);
      drawerOverlay.removeEventListener('click', closeMenu);
      mobileDrawer.removeEventListener('click', onDrawerLinkClick);
      document.removeEventListener('keydown', onKeydown);
      closeMenuDirectly();
    };
  };

  const bindHeaderScroll = () => {
    const header = document.getElementById('main-header');
    if (!header) return () => {};

    const isHome = header.getAttribute('data-is-home') === 'true';

    const handleScroll = () => {
      if (!isHome) return;

      if (window.scrollY > 50) {
        header.classList.add('header-scrolled', 'text-primary');
        header.classList.remove('py-4', 'md:py-6', 'text-bg-landing', 'bg-bg-landing/12', 'backdrop-blur-sm', 'border-bg-landing/25');
      } else {
        header.classList.remove('header-scrolled', 'text-primary');
        header.classList.add('py-4', 'md:py-6', 'text-bg-landing', 'bg-bg-landing/12', 'backdrop-blur-sm', 'border-bg-landing/25');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
    return () => window.removeEventListener('scroll', handleScroll);
  };

  let teardownMobileMenu: (() => void) | undefined;
  let teardownHeaderScroll: (() => void) | undefined;

  document.addEventListener('astro:after-preparation', () => {
    closeMenuDirectly();
  });

  document.addEventListener('astro:page-load', () => {
    closeMenuDirectly();
    teardownMobileMenu?.();
    teardownHeaderScroll?.();
    teardownMobileMenu = bindMobileMenu();
    teardownHeaderScroll = bindHeaderScroll();
  });
</script>
