---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

// Recibimos el link alternativo y el idioma actual del Layout
const { language, alternateLink } = Astro.props;

// Diccionario básico para elementos de la interfaz
const t = {
	es: { home: 'Inicio', blog: 'Blog', about: 'Sobre mí', join: 'Únete a la lista' },
	en: { home: 'Home', blog: 'Blog', about: 'About', join: 'Join the list' }
};

const nav = t[language as 'es' | 'en'] || t.es;
---

<header>
	<nav>
		<div class="nav-left">
			<a href={`/${language}/blog/`} class="logo">
				SL<span>O</span>WORK
			</a>
		</div>

		<div class="internal-links">
			<HeaderLink href={`/${language}/blog/`}>{nav.blog}</HeaderLink>
			<HeaderLink href="/about">{nav.about}</HeaderLink>
		</div>

		<div class="nav-right">
			<div class="lang-selector">
				<a href={alternateLink} class={language === 'es' ? 'active' : ''}>ES</a>
				<span>|</span>
				<a href={alternateLink} class={language === 'en' ? 'active' : ''}>EN</a>
			</div>
			
			<a  target="_blank" href="https://www.slowork.app/es" class="cta-button">
				{nav.join}
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0.5rem 2rem;
		background: #0f1a16; /* Verde muy oscuro de la imagen */
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Logo Estilo SloWork */
	.logo {
		color: white;
		text-decoration: none;
		font-weight: 800;
		font-size: 1.5rem;
		letter-spacing: 2px;
	}
	.logo span {
		color: #e6d445; /* Amarillo de la landing */
	}

	.internal-links {
		display: flex;
		gap: 1.5rem;
	}

	.internal-links a {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		transition: color 0.3s ease;
	}

	.internal-links a:hover, .internal-links a.active {
		color: #e6d445;
	}

	.nav-right {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	/* Selector de Idioma */
	.lang-selector {
		display: flex;
		gap: 0.5rem;
		color: white;
		font-size: 0.8rem;
		font-weight: bold;
	}
	.lang-selector a {
		color: rgba(255, 255, 255, 0.5);
		text-decoration: none;
	}
	.lang-selector a.active {
		color: #e6d445;
	}

	/* Botón Amarillo "Únete" */
	.cta-button {
		background: #e6d445;
		color: #0f1a16;
		padding: 0.6rem 1.2rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: bold;
		font-size: 0.85rem;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.cta-button:hover {
		transform: scale(1.05);
		background: #f3e03b;
	}

	@media (max-width: 720px) {
		.internal-links, .cta-button {
			display: none;
		}
	}
</style>