---
import Logo from './Logo.astro';

const { language, alternateLink } = Astro.props;

const t = {
  es: { blog: 'BLOG', about: 'ABOUT', join: 'Únete a la lista de espera' },
  en: { blog: 'BLOG', about: 'ABOUT', join: 'Join the waiting list' }
};
const nav = t[language as 'es' | 'en'] || t.es;
---

<header class="absolute top-0 left-0 w-full z-50 bg-transparent py-8">
  <nav class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    
    <div class="flex-shrink-0">
      <Logo language={language} />
    </div>

    <div class="flex items-center gap-4 md:gap-8">
      
      <div class="relative">
        <button 
          id="menu-button" 
          class="flex items-center gap-2 text-primary hover:opacity-70 transition-opacity font-bold text-sm tracking-widest p-2"
          aria-label="Abrir menú"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
          </svg>
          <span class="hidden sm:inline">MENÚ</span>
        </button>

        <div id="menu-dropdown" class="hidden absolute right-0 mt-4 w-48 bg-white/90 backdrop-blur-md rounded-2xl shadow-xl border border-primary/5 py-4 z-50">
          <a href={`/${language}/blog/`} class="block px-6 py-3 text-sm font-bold text-primary hover:bg-secondary/20 transition-colors">{nav.blog}</a>
          <a href="/about" class="block px-6 py-3 text-sm font-bold text-primary hover:bg-secondary/20 transition-colors">{nav.about}</a>
        </div>
      </div>

      <div class="flex items-center gap-3 text-xs font-bold border-l border-primary/10 pl-4 md:pl-6 text-primary">
        <a href={alternateLink} class={language === 'es' ? 'opacity-100' : 'opacity-40'}>ES</a>
        <span class="opacity-20">|</span>
        <a href={alternateLink} class={language === 'en' ? 'opacity-100' : 'opacity-40'}>EN</a>
      </div>

      <a href="https://slowork.com" 
         class="bg-secondary text-primary px-5 py-2.5 rounded-full font-bold text-[13px] shadow-md transition-transform hover:scale-105 active:scale-95 whitespace-nowrap">
        {nav.join}
      </a>
    </div>
  </nav>
</header>

<script>
  const menuButton = document.getElementById('menu-button');
  const menuDropdown = document.getElementById('menu-dropdown');

  // Abrir/Cerrar menú al hacer click
  menuButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    menuDropdown?.classList.toggle('hidden');
  });

  // Cerrar si se hace click fuera del menú
  document.addEventListener('click', () => {
    menuDropdown?.classList.add('hidden');
  });
</script>

<style>
  /* Animación suave para el menú */
  #menu-dropdown:not(.hidden) {
    animation: fadeInDown 0.2s ease-out;
  }

  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>