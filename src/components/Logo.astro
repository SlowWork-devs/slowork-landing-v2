---
import { Image } from 'astro:assets';
import type { SupportedLang } from '@/lib/seo';
import logoImg from '@/assets/logo-slowork.png';

interface Props {
  language: SupportedLang;
  class?: string;
}

const { language, class: className = '' } = Astro.props;
const homeHref = `/${language}/`;
---
<a
  href={homeHref}
  class={`flex min-h-11 min-w-11 touch-manipulation items-center ${className}`.trim()}
  aria-label="SloWork - Ir al inicio"
>
  <Image 
    src={logoImg} 
    alt="SloWork Logo" 
    width={200} 
    class="h-10 w-auto object-contain logo-image transition-all duration-500"
    loading="eager"
  />
</a>