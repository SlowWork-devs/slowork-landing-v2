---
import { Image } from 'astro:assets';
import FormattedDate from '@/components/FormattedDate.astro';

const { post, eager = false } = Astro.props;
const { title, date, image, localImage, excerpt, language } = post.data;

const slug = post.id.split('/').pop()?.replace(/\.(md|mdx)$/, '');
const postUrl = `/${language}/blog/${slug}/`;
---

<a 
  href={postUrl} 
  class="post-card group block h-full min-h-[280px] w-full rounded-2xl overflow-hidden bg-white border border-primary/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 ease-out text-left no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-white touch-manipulation"
>
  <div class="aspect-video w-full overflow-hidden bg-primary/5">
    {localImage ? (
      <Image 
        width={720} 
        height={400} 
        src={localImage} 
        alt={title}
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        format="webp"
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : (
      <img 
        src={image} 
        alt={title} 
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    )}
  </div>
  <div class="p-5 sm:p-6 flex flex-col grow">
    <p class="text-xs text-primary/70 uppercase tracking-wider mb-2">
      <FormattedDate date={date} />
    </p>
    <h2 class="font-heading font-bold text-primary text-xl sm:text-2xl leading-snug mb-3 line-clamp-2">
      {title}
    </h2>
    <p class="text-primary/80 text-base leading-relaxed mb-4 grow line-clamp-3">
      {excerpt}
    </p>
    <span class="inline-flex items-center gap-2 font-bold text-primary text-sm sm:text-base group-hover:text-secondary transition-colors">
      {language === 'es' ? 'Leer más' : 'Read more'}
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>
