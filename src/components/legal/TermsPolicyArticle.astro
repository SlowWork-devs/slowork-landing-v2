---
import { termsLinkify } from '@/lib/termsRichText';
import type { SupportedLang } from '@/lib/seo';
import type { TermsAndConditionsContent } from '@/models/legal';

interface Props {
  terms: TermsAndConditionsContent;
  lang: SupportedLang;
  /** When `false`, omits the page `<h1>` and date (e.g. dialog already shows the title in chrome). */
  showDocumentTitle?: boolean;
}

const { terms, lang, showDocumentTitle = true } = Astro.props;

const dataProtectionHtml = termsLinkify(terms.dataProtection, lang);
const law3Html = termsLinkify(terms.law3, lang);
---

<article class="prose legal-doc max-w-none">
  {
    showDocumentTitle ? (
      <>
        <h1>{terms.title}</h1>
        <p>{terms.date}</p>
      </>
    ) : null
  }

  <h2>{terms.generalInfoTitle}</h2>
  <p class="whitespace-pre-line">{terms.generalInfo}</p>

  <h2>{terms.purposeTitle}</h2>
  <p>{terms.purpose}</p>

  <h2>{terms.waitlistTitle}</h2>
  <p>{terms.waitlist1}</p>
  <p>{terms.waitlist2}</p>
  <p>{terms.waitlist3}</p>

  <h2>{terms.ipTitle}</h2>
  <p>{terms.ip}</p>

  <h2>{terms.acceptableUseTitle}</h2>
  <p class="whitespace-pre-line">{terms.acceptableUse}</p>

  <h2>{terms.dataProtectionTitle}</h2>
  <p set:html={dataProtectionHtml} />

  <h2>{terms.liabilityTitle}</h2>
  <p>{terms.liability1}</p>
  <p>{terms.liability2}</p>

  <h2>{terms.modificationsTitle}</h2>
  <p>{terms.modifications}</p>

  <h2>{terms.lawTitle}</h2>
  <p class="whitespace-pre-line">{terms.law1}</p>
  <p class="whitespace-pre-line">{terms.law2}</p>
  <p set:html={law3Html} />
  <p>{terms.law4}</p>
  <p>{terms.law5}</p>
</article>
