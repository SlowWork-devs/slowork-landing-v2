---
export const prerender = true;

export async function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') {
  return Astro.redirect('/en/', 302);
}

const posts = (await getCollection('blog', ({ data }) => data.language === lang)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const alternateLang = lang === 'es' ? 'en' : 'es';
const alternateLink = `/${alternateLang}/blog/`;
const esBlogIndex = new URL('/es/blog/', Astro.url.origin).href;
const enBlogIndex = new URL('/en/blog/', Astro.url.origin).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
		<link rel="alternate" hreflang="es" href={esBlogIndex} />
		<link rel="alternate" hreflang="en" href={enBlogIndex} />
		<link rel="alternate" hreflang="x-default" href={esBlogIndex} />
	</head>
	<body class="min-w-0 overflow-x-hidden">
		<Header language={lang} alternateLink={alternateLink} />

		<main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">
			<header class="text-center mb-12 sm:mb-16 md:mb-20 animate-fade-in-down">
				<h1 class="font-heading font-bold text-primary mb-6 text-[clamp(1.75rem,5vw+1rem,3.75rem)] leading-tight tracking-tight">
					SloWork Blog
				</h1>
				<div class="w-24 h-1.5 bg-secondary mx-auto rounded-full mb-6 md:mb-8"></div>
				<p class="text-primary/80 max-w-2xl mx-auto leading-relaxed text-base sm:text-lg md:text-xl">
					{lang === 'es'
						? 'Rediseña tu mundo. Guías y reflexiones para confirmar que otro estilo de vida es posible.'
						: 'Redesign your world. Guides and reflections to confirm another way of life is possible.'}
				</p>
			</header>

			<section class="w-full min-w-0">
				<ul class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8 xl:gap-10 list-none p-0">
					{posts.map((post, index) => (
						<li class="h-full min-w-0 w-full">
							<PostCard post={post} eager={index === 0} />
						</li>
					))}
				</ul>
			</section>
		</main>

		<Footer language={lang} />
	</body>
</html>

