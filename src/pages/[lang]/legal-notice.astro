---
import MainLayout from '@/layouts/MainLayout.astro';
import LegalDocumentShell from '@/components/legal/LegalDocumentShell.astro';
import LegalNoticeArticle from '@/components/legal/LegalNoticeArticle.astro';
import { buildI18nAlternates } from '@/lib/hreflang';
import { getLegalBundle } from '@/lib/legalBundle';
import type { SupportedLang } from '@/lib/seo';

const lang = Astro.params.lang as SupportedLang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const bundle = getLegalBundle(lang);
const legal = bundle.legalNotice;
const { alternates } = buildI18nAlternates(Astro.url.origin, '/legal-notice/', lang);

const title = legal.helmet.title;
const description = legal.helmet.description;
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/legal-notice/`}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: legal.heading,
    description,
    url: new URL(`/${lang}/legal-notice/`, Astro.url.origin).href,
  }}
>
  <LegalDocumentShell>
    <LegalNoticeArticle legal={legal} />
  </LegalDocumentShell>
</MainLayout>
