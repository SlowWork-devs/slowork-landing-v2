---
import MainLayout from '../../layouts/MainLayout.astro';
import { SITE_TITLE } from '../../consts';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const alternateLang = lang === 'es' ? 'en' : 'es';
const alternateLink = `/${alternateLang}/about-us/`;

const title = `${lang === 'es' ? 'Sobre nosotros' : 'About us'} | ${SITE_TITLE}`;
const description = lang === 'es' ? 'Conoce la historia de Slowork.' : 'Learn the story behind Slowork.';
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/about-us/`}
  headerAlternateLink={alternateLink}
  alternates={[
    { hreflang: lang, href: Astro.url.href },
    { hreflang: alternateLang, href: new URL(alternateLink, Astro.url.origin).href },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: lang === 'es' ? 'Sobre nosotros' : 'About us',
    description,
    url: `https://www.slowork.app/${lang}/about-us/`,
  }}
>
  <main class="w-full max-w-5xl mx-auto px-6 pt-32 pb-16 md:py-24">
    <h1 class="font-heading font-bold text-primary text-4xl sm:text-5xl tracking-tight">
      {lang === 'es' ? 'Sobre nosotros' : 'About us'}
    </h1>
    <p class="mt-6 text-primary/80 text-lg leading-relaxed max-w-3xl">
      {lang === 'es'
        ? 'En Slowork creemos que el trabajo remoto no debería significar aislamiento ni viajes con prisa. Queremos crear una forma de vivir y trabajar más humana, sostenible y conectada.'
        : "At Slowork we believe remote work shouldn’t mean isolation or rushed travel. We’re building a more human, sustainable, and connected way to live and work."}
    </p>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white/70 rounded-2xl p-6 border border-primary/5 shadow-sm">
        <h2 class="font-heading font-bold text-primary text-2xl">{lang === 'es' ? 'Nuestra misión' : 'Our mission'}</h2>
        <p class="mt-3 text-primary/80 leading-relaxed">
          {lang === 'es'
            ? 'Conectar a trabajadores remotos con espacios y comunidades eco-conscientes para que productividad y bienestar convivan.'
            : 'Connect remote workers with eco-conscious spaces and communities where productivity and wellbeing coexist.'}
        </p>
      </div>
      <div class="bg-white/70 rounded-2xl p-6 border border-primary/5 shadow-sm">
        <h2 class="font-heading font-bold text-primary text-2xl">{lang === 'es' ? 'Lo que defendemos' : 'What we stand for'}</h2>
        <ul class="mt-3 space-y-2 text-primary/80">
          <li>• {lang === 'es' ? 'Naturaleza como catalizador' : 'Nature as a catalyst'}</li>
          <li>• {lang === 'es' ? 'Comunidad real' : 'Real community'}</li>
          <li>• {lang === 'es' ? 'Viaje consciente' : 'Conscious travel'}</li>
        </ul>
      </div>
    </div>
  </main>
</MainLayout>

