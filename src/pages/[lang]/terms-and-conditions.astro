---
import MainLayout from '@/layouts/MainLayout.astro';
import LegalDocumentShell from '@/components/legal/LegalDocumentShell.astro';
import TermsPolicyArticle from '@/components/legal/TermsPolicyArticle.astro';
import { buildI18nAlternates } from '@/lib/hreflang';
import { getLegalBundle } from '@/lib/legalBundle';
import type { SupportedLang } from '@/lib/seo';

const lang = Astro.params.lang as SupportedLang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const bundle = getLegalBundle(lang);
const terms = bundle.termsAndConditions;
const { alternates } = buildI18nAlternates(
  Astro.url.origin,
  '/terms-and-conditions/',
  lang,
);

const title = terms.helmet.title;
const description = terms.helmet.description;
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/terms-and-conditions/`}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: terms.title,
    description,
    url: new URL(`/${lang}/terms-and-conditions/`, Astro.url.origin).href,
  }}
>
  <LegalDocumentShell>
    <TermsPolicyArticle terms={terms} lang={lang} />
  </LegalDocumentShell>
</MainLayout>
