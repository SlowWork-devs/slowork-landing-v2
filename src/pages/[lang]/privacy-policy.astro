---
import MainLayout from '@/layouts/MainLayout.astro';
import PrivacyPolicyArticle from '@/components/legal/PrivacyPolicyArticle.astro';
import { buildI18nAlternates } from '@/lib/hreflang';
import { getLegalBundle } from '@/lib/legalBundle';
import type { SupportedLang } from '@/lib/seo';

const lang = Astro.params.lang as SupportedLang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const bundle = getLegalBundle(lang);
const privacy = bundle.privacyPolicy;
const { alternates, headerAlternateLink } = buildI18nAlternates(Astro.url.origin, '/privacy-policy/', lang);

const title = privacy.helmet.title;
const description = privacy.helmet.description;
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/privacy-policy/`}
  headerAlternateLink={headerAlternateLink}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: privacy.heading,
    description,
    url: new URL(`/${lang}/privacy-policy/`, Astro.url.origin).href,
  }}
>
  <main class="mx-auto w-full max-w-4xl px-6 pb-20 pt-32 md:py-24">
    <div class="rounded-2xl border border-primary/10 bg-white/75 p-6 shadow-sm sm:p-10 md:p-12">
      <PrivacyPolicyArticle privacy={privacy} />
    </div>
  </main>
</MainLayout>
