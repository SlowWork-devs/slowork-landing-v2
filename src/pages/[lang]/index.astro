---
import MainLayout from '../../layouts/MainLayout.astro';
import { heroCombinations } from '../../lib/homeContent';
import HomeHero from '../../components/home/HomeHero.astro';
import HomeValueProposition from '../../components/home/HomeValueProposition.astro';
import HomeFeatures from '../../components/home/HomeFeatures.astro';
import HomeGlobeSection from '../../components/home/HomeGlobeSection.astro';
import HomeJourney from '../../components/home/HomeJourney.astro';
import HomeWhoFor from '../../components/home/HomeWhoFor.astro';
import HomeFinalCta from '../../components/home/HomeFinalCta.astro';
import HomeStickyWaitlist from '../../components/home/HomeStickyWaitlist.astro';
import HomeWaitlistModal from '../../components/home/HomeWaitlistModal.astro';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') {
  return Astro.redirect('/en/', 302);
}

const alternateLang = lang === 'es' ? 'en' : 'es';
const alternateLink = `/${alternateLang}/`;

const title =
  lang === 'es' ? 'Slowork - Tu Comunidad de Trabajo Remoto' : 'Slowork - Your Remote Work Community';
const description =
  lang === 'es'
    ? 'Descubre espacios sostenibles, conecta con nómadas digitales y redefine tu forma de trabajar.'
    : 'Discover sustainable spaces, connect with digital nomads, and redefine how you work.';
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/`}
  headerAlternateLink={alternateLink}
  alternates={[
    { hreflang: lang, href: Astro.url.href },
    { hreflang: alternateLang, href: new URL(alternateLink, Astro.url.origin).href },
  ]}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Slowork',
    description,
    url: `https://www.slowork.app/${lang}/`,
  }}
>
  <main class="w-full">
    <HomeHero lang={lang} />
    <HomeValueProposition lang={lang} />
    <HomeFeatures lang={lang} />
    <HomeGlobeSection lang={lang} />
    <HomeJourney lang={lang} />
    <HomeWhoFor lang={lang} />
    <HomeFinalCta lang={lang} />
  </main>

  <HomeStickyWaitlist lang={lang} />
  <HomeWaitlistModal lang={lang} />

  <script is:inline define:vars={{ heroCombinations: heroCombinations(lang), lang }}>
    (() => {
      const combos = heroCombinations;
      const firstEl = document.getElementById('hero-first');
      const phraseEl = document.getElementById('hero-phrase');
      let heroIdx = 0;
      const tickHero = () => {
        const c = combos[heroIdx % combos.length];
        if (firstEl) firstEl.textContent = c.first;
        if (phraseEl) phraseEl.textContent = c.phrase;
        heroIdx += 1;
      };
      tickHero();
      setInterval(tickHero, 2800);

      const overlay = document.getElementById('modal-overlay');
      const modal = document.getElementById('waitlist-modal');
      const openModal = () => {
        overlay?.classList.remove('hidden');
        modal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      };
      const closeModal = () => {
        overlay?.classList.add('hidden');
        modal?.classList.add('hidden');
        document.body.style.overflow = '';
      };
      document.querySelectorAll('[data-open-waitlist]').forEach((btn) => {
        btn.addEventListener('click', openModal);
      });
      overlay?.addEventListener('click', closeModal);
      document.getElementById('close-waitlist')?.addEventListener('click', closeModal);

      const form = document.getElementById('waitlist-form');
      const msg = document.getElementById('waitlist-message');
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (msg) msg.textContent = lang === 'es' ? 'Enviando...' : 'Sending...';
        const token = window.grecaptcha?.getResponse?.() || '';
        if (!token) {
          if (msg) msg.textContent = lang === 'es' ? 'Completa el reCAPTCHA.' : 'Please complete reCAPTCHA.';
          return;
        }
        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());
        const verify = await fetch('/api/verify-recaptcha', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ token }),
        });
        if (!verify.ok) {
          if (msg) msg.textContent = lang === 'es' ? 'reCAPTCHA inválido.' : 'Invalid reCAPTCHA.';
          return;
        }
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => null);
        if (!res.ok) {
          if (msg)
            msg.textContent = data?.message || (lang === 'es' ? 'Error al registrar.' : 'Registration error.');
          return;
        }
        fetch('/api/welcome', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ name: payload.firstName, email: payload.email, lang }),
        }).catch(() => {});
        if (msg) msg.textContent = lang === 'es' ? '¡Listo! Revisa tu email.' : 'Done! Check your email.';
        form.reset();
        window.grecaptcha?.reset?.();
        closeModal();
      });

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('is-visible');
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' },
      );
      document.querySelectorAll('[data-home-reveal]').forEach((el) => io.observe(el));
    })();
  </script>

  <script is:inline src="https://www.google.com/recaptcha/api.js" async defer></script>
</MainLayout>
