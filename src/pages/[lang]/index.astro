---
import MainLayout from '../../layouts/MainLayout.astro';
import { heroCombinations } from '../../lib/homeContent';
import HomeHero from '../../components/home/HomeHero.astro';
import HomeValueProposition from '../../components/home/HomeValueProposition.astro';
import HomeFeatures from '../../components/home/HomeFeatures.astro';
import HomeGlobeSection from '../../components/home/HomeGlobeSection.astro';
import HomeJourney from '../../components/home/HomeJourney.astro';
import HomeWhoFor from '../../components/home/HomeWhoFor.astro';
import HomeFinalCta from '../../components/home/HomeFinalCta.astro';
import HomeStickyWaitlist from '../../components/home/HomeStickyWaitlist.astro';
import HomeWaitlistModal from '../../components/home/HomeWaitlistModal.astro';
import { buildI18nAlternates } from '../../lib/hreflang';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') {
  return Astro.redirect('/en/', 302);
}

const { alternates, headerAlternateLink } = buildI18nAlternates(Astro.url.origin, '/', lang);

const title =
  lang === 'es' ? 'Slowork - Tu Comunidad de Trabajo Remoto' : 'Slowork - Your Remote Work Community';
const description =
  lang === 'es'
    ? 'Descubre espacios sostenibles, conecta con nómadas digitales y redefine tu forma de trabajar.'
    : 'Discover sustainable spaces, connect with digital nomads, and redefine how you work.';
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/`}
  headerAlternateLink={headerAlternateLink}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Slowork',
    description,
    url: `https://www.slowork.app/${lang}/`,
  }}
>
  <main class="w-full">
    <HomeHero lang={lang} />
    <HomeValueProposition lang={lang} />
    <HomeFeatures lang={lang} />
    <HomeGlobeSection lang={lang} />
    <HomeJourney lang={lang} />
    <HomeWhoFor lang={lang} />
    <HomeFinalCta lang={lang} />
  </main>

  <HomeStickyWaitlist lang={lang} />
  <HomeWaitlistModal lang={lang} />

  <script is:inline define:vars={{ heroCombinations: heroCombinations(lang), lang }}>
    (() => {
      const combos = heroCombinations;
      const firstEl = document.getElementById('hero-first');
      const phraseEl = document.getElementById('hero-phrase');
      const hero = { index: 0 };
      const tickHero = () => {
        const c = combos[hero.index % combos.length];
        if (firstEl) firstEl.textContent = c.first;
        if (phraseEl) phraseEl.textContent = c.phrase;
        hero.index += 1;
      };
      tickHero();
      setInterval(tickHero, 2800);

      const overlay = document.getElementById('modal-overlay');
      const modal = document.getElementById('waitlist-modal');
      const openModal = () => {
        overlay?.classList.remove('hidden');
        modal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      };
      const closeModal = () => {
        overlay?.classList.add('hidden');
        modal?.classList.add('hidden');
        document.body.style.overflow = '';
      };
      document.querySelectorAll('[data-open-waitlist]').forEach((btn) => {
        btn.addEventListener('click', openModal);
      });
      overlay?.addEventListener('click', closeModal);
      document.getElementById('close-waitlist')?.addEventListener('click', closeModal);

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('is-visible');
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -10% 0px' },
      );
      document.querySelectorAll('[data-home-reveal]').forEach((el) => io.observe(el));
    })();
  </script>
</MainLayout>
