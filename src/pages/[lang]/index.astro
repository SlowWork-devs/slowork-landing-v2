---
import { getImage } from 'astro:assets';

import MainLayout from '@/layouts/MainLayout.astro';
import HomeHero from '@/components/home/HomeHero.astro';
import HomeValueProposition from '@/components/home/HomeValueProposition.astro';
import HomeFeatures from '@/components/home/HomeFeatures.astro';
import HomeGlobeSection from '@/components/home/HomeGlobeSection.astro';
import HomeJourney from '@/components/home/HomeJourney.astro';
import HomeWhoFor from '@/components/home/HomeWhoFor.astro';
import HomeContact from '@/components/home/HomeContact.astro';
import HomeFinalCta from '@/components/home/HomeFinalCta.astro';
import HomeStickyWaitlist from '@/components/home/HomeStickyWaitlist.astro';
import { buildI18nAlternates } from '@/lib/hreflang';
import { HOME_MEDIA } from '@/lib/homeContent';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') {
  return Astro.redirect('/en/', 302);
}

const { alternates } = buildI18nAlternates(Astro.url.origin, '/', lang);

const title =
  lang === 'es' ? 'Slowork - Tu Comunidad de Trabajo Remoto' : 'Slowork - Your Remote Work Community';
const description =
  lang === 'es'
    ? 'Descubre espacios sostenibles, conecta con nómadas digitales y redefine tu forma de trabajar.'
    : 'Discover sustainable spaces, connect with digital nomads, and redefine how you work.';

/** Misma variante que el `poster` del hero: el buscador del LCP la ve en el HTML sin esperar al vídeo. */
const heroLcpPoster = await getImage({
  src: HOME_MEDIA.videoPoster,
  width: 1920,
  format: 'webp',
  quality: 82,
});
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/`}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Slowork',
    alternateName: lang === 'es' ? 'Slowork — landing principal' : 'Slowork — main landing',
    description,
    url: `https://www.slowork.app/${lang}/`,
    inLanguage: lang === 'es' ? 'es' : 'en',
    publisher: { '@type': 'Organization', name: 'Slowork' },
  }}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroLcpPoster.src}
    type="image/webp"
    fetchpriority="high"
  />

  <main class="w-full">
    <HomeHero lang={lang} />
    <HomeValueProposition lang={lang} />
    <HomeFeatures lang={lang} />
    <HomeGlobeSection lang={lang} />
    <HomeJourney lang={lang} />
    <HomeWhoFor lang={lang} />
    <HomeContact lang={lang} />
    <HomeFinalCta lang={lang} />
  </main>

  <HomeStickyWaitlist lang={lang} />

  <script>
    let homeRevealCleanup: (() => void) | undefined;

    document.addEventListener('astro:page-load', () => {
      homeRevealCleanup?.();

      const nodes = document.querySelectorAll<HTMLElement>(
        '[data-home-reveal], [data-globe-reveal]',
      );
      if (nodes.length === 0) {
        homeRevealCleanup = undefined;
        return;
      }

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            if (el.hasAttribute('data-globe-reveal')) {
              el.classList.add('globe-in-view');
            } else {
              const delay = el.dataset.revealDelay;
              if (delay) el.style.transitionDelay = `${delay}ms`;
              el.classList.add('is-visible');
            }
            io.unobserve(el);
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -8% 0px' },
      );

      nodes.forEach((el) => io.observe(el));
      homeRevealCleanup = () => io.disconnect();
    });
  </script>
</MainLayout>
