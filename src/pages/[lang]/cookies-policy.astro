---
import MainLayout from '@/layouts/MainLayout.astro';
import LegalDocumentShell from '@/components/legal/LegalDocumentShell.astro';
import CookiesPolicyArticle from '@/components/legal/CookiesPolicyArticle.astro';
import { buildI18nAlternates } from '@/lib/hreflang';
import { getLegalBundle } from '@/lib/legalBundle';
import type { SupportedLang } from '@/lib/seo';

const lang = Astro.params.lang as SupportedLang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const bundle = getLegalBundle(lang);
const cookies = bundle.cookiesPolicy;
const { alternates } = buildI18nAlternates(Astro.url.origin, '/cookies-policy/', lang);

const title = cookies.helmet.title;
const description = cookies.helmet.description;
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/cookies-policy/`}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: cookies.heading,
    description,
    url: new URL(`/${lang}/cookies-policy/`, Astro.url.origin).href,
  }}
>
  <LegalDocumentShell>
    <CookiesPolicyArticle cookies={cookies} />
  </LegalDocumentShell>
</MainLayout>
