---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';

// 1. Obtenemos posts en español y ordenamos por fecha
const posts = (await getCollection('blog', ({ data }) => {
	return data.language === 'en';
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const lang = 'en';
const alternateLink = '/es/blog/';
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${SITE_TITLE} | Blog`} description={SITE_DESCRIPTION} />
		<link rel="alternate" hreflang="en" href={Astro.url.href} />
		<link rel="alternate" hreflang="es" href={new URL(alternateLink, Astro.url.origin).href} />
	</head>
	<body>
		<Header language={lang} alternateLink={alternateLink} />
		
		<main class="max-w-7xl mx-auto px-6 py-16 md:py-24">
			<header class="text-center mb-20 animate-fade-in-down">
				<h1 class="text-4xl md:text-6xl font-heading font-bold text-primary mb-6">
					SloWork Blog
				</h1>
				<div class="w-24 h-1.5 bg-secondary mx-auto rounded-full mb-8"></div>
				<p class="text-primary/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
					Redesign your world. Guides and reflections to confirm another way of life is possible.
				</p>
			</header>

			<section>
				<ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12 list-none p-0">
					{posts.map((post) => (
						<li class="h-full">
							<PostCard post={post} />
						</li>
					))}
				</ul>
			</section>
		</main>

		<Footer language={lang} />
	</body>
</html>