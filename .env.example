# -----------------------------
# Analytics (GA4 / gtag; opcional)
# -----------------------------
# Measurement ID (p. ej. G-XXXXXXXX). Carga vía Partytown en MainLayout (no bloquea LCP).
# PUBLIC_GA_ID=

# -----------------------------
# Runtime / Deploy (Vercel)
# -----------------------------

# Used for preview deployments to build correct absolute URLs (canonical/sitemap).
# Vercel automatically provides this in its environment.
# VERCEL_URL=your-preview.vercel.app

# -----------------------------
# Database (AWS RDS Postgres)
# -----------------------------

# Prisma expects DATABASE_URL.
# Prefer setting DATABASE_URL in Vercel.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Legacy / explicit parts (supported by src/lib/prisma.ts as a fallback builder)
DB_HOST_LANDING=
DB_PORT_LANDING=5432
DB_NAME_LANDING=
DB_USER_LANDING=
DB_PASS_LANDING=
DB_SSL_LANDING=true

# -----------------------------
# Email (Office365 SMTP)
# -----------------------------

GODADDY_EMAIL=
GODADDY_PASS=
