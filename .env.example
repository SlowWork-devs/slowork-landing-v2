# -----------------------------
# Analytics (GA4 / gtag; opcional)
# -----------------------------
# Measurement ID (p. ej. G-XXXXXXXX). Carga vía Partytown en MainLayout (no bloquea LCP).
# PUBLIC_GA_ID=

# -----------------------------
# Runtime / Deploy (Vercel)
# -----------------------------

# Used for preview deployments to build correct absolute URLs (canonical/sitemap).
# Vercel automatically provides this in its environment.
# VERCEL_URL=your-preview.vercel.app

# -----------------------------
# Slowork API (GraphQL + REST waitlist / welcome)
# -----------------------------

# Base URL of the backend (no trailing path). Required for blog (GraphQL) and
# POST /api/waitlist proxy in production-like local testing.
# SLOWORK_API_URL=https://api.example.com

# -----------------------------
# Database (AWS RDS Postgres)
# -----------------------------

# Prisma expects DATABASE_URL.
# Prefer setting DATABASE_URL in Vercel.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Legacy / explicit parts (supported by src/lib/prisma.ts as a fallback builder)
DB_HOST_LANDING=
DB_PORT_LANDING=5432
DB_NAME_LANDING=
DB_USER_LANDING=
DB_PASS_LANDING=
DB_SSL_LANDING=true

# -----------------------------
# Email (Office365 SMTP)
# -----------------------------

GODADDY_EMAIL=
GODADDY_PASS=

# Opcional: credenciales explícitas para SMTP (si no se definen, se usan GODADDY_*).
# EMAIL_SERVER_HOST=smtp.office365.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=

# Destinatario del formulario de contacto (por defecto sloworking.adm@gmail.com).
# CONTACT_MAIL_TO=sloworking.adm@gmail.com
# CONTACT_MAIL_FROM="Slowork" <slowork@slowork.app>
